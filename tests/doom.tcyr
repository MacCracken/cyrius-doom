# doom.tcyr -- cyrius-doom test suite
# Run: cyrius test tests/doom.tcyr
#   or: cat tests/doom.tcyr | cc2 > build/test && chmod +x build/test && ./build/test wad/DOOM1.WAD

include "lib/string.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/fmt.cyr"
include "lib/io.cyr"
include "lib/args.cyr"
include "lib/assert.cyr"
include "lib/sakshi.cyr"

include "lib/bsp.cyr"
include "src/fixed.cyr"
include "src/tables.cyr"
include "src/wad.cyr"
include "src/framebuf.cyr"
include "src/map.cyr"
include "src/texture.cyr"
include "src/render.cyr"
include "src/input.cyr"
include "src/player.cyr"
include "src/things.cyr"
include "src/sprite.cyr"
# music.cyr needs only SND_DMX_RATE from audio.cyr (not otherwise included here).
enum MusRateStub { SND_DMX_RATE = 11025; }
include "src/music.cyr"

# Hermetic no-op stubs for cross-module side-effects the combat path calls.
# sound.cyr / level.cyr / tick.cyr / doors.cyr aren't included here (they pull
# in device I/O and map state the unit tests don't want), so their symbols are
# otherwise undefined — and calling an undefined function jumps to an
# unresolved address and segfaults. Stubbing them keeps the test hermetic.
fn sound_pistol(): i64 { return 0; }
fn sound_shotgun(): i64 { return 0; }
fn sound_plasma(): i64 { return 0; }
fn sound_explode(): i64 { return 0; }
fn sound_weapon_dry(): i64 { return 0; }
fn sound_player_pain(): i64 { return 0; }
fn sound_monster_pain(): i64 { return 0; }
fn sound_monster_die(): i64 { return 0; }
fn sound_item_pickup(): i64 { return 0; }
fn audio_play_name(lump_name): i64 { return 0; }
fn audio_play_at(lump_name, sx, sy): i64 { return 0; }
fn level_add_kill(): i64 { return 0; }
fn level_add_item(): i64 { return 0; }
fn tick_get_count(): i64 { return 0; }
fn doors_walk_trigger(ox, oy, nx, ny): i64 { return 0; }

fn main() {
    alloc_init();
    args_init();

    # ============================================================
    test_group("asr (arithmetic shift right)");
    # ============================================================

    assert_eq(asr(256, 4), 16, "asr(256,4) = 16");
    assert_eq(asr(0, 8), 0, "asr(0,8) = 0");
    assert_eq(asr(1, 0), 1, "asr(1,0) = 1");

    # Negative values — the critical case
    var neg100 = 0 - 100;
    assert_eq(asr(neg100, 1), 0 - 50, "asr(-100,1) = -50");
    assert_eq(asr(neg100, 2), 0 - 25, "asr(-100,2) = -25");

    # ============================================================
    test_group("fixed-point conversion");
    # ============================================================

    assert_eq(fixed_from_int(0), 0, "from_int(0)");
    assert_eq(fixed_from_int(1), 65536, "from_int(1)");
    assert_eq(fixed_from_int(100), 6553600, "from_int(100)");

    assert_eq(fixed_to_int(65536), 1, "to_int(1.0)");
    assert_eq(fixed_to_int(131072), 2, "to_int(2.0)");
    assert_eq(fixed_to_int(0), 0, "to_int(0)");

    # Negative round-trip
    var neg5 = fixed_from_int(0 - 5);
    assert_eq(fixed_to_int(neg5), 0 - 5, "to_int(from_int(-5)) = -5");
    var neg1000 = fixed_from_int(0 - 1000);
    assert_eq(fixed_to_int(neg1000), 0 - 1000, "to_int(from_int(-1000)) = -1000");

    # ============================================================
    test_group("fixed-point arithmetic");
    # ============================================================

    var a10 = fixed_from_int(10);
    var a3 = fixed_from_int(3);

    assert_eq(fixed_to_int(fixed_mul(a10, a3)), 30, "10*3 = 30");
    assert_eq(fixed_to_int(fixed_div(a10, a3)), 3, "10/3 = 3 (trunc)");
    assert_eq(fixed_div(a10, 0), FIXED_MAX, "div by zero = MAX");

    # Negative multiplication
    var neg3 = fixed_from_int(0 - 3);
    assert_eq(fixed_to_int(fixed_mul(a10, neg3)), 0 - 30, "10 * -3 = -30");
    assert_eq(fixed_to_int(fixed_mul(neg3, neg3)), 9, "-3 * -3 = 9");

    # Abs
    assert_eq(fixed_abs(neg3), a3, "abs(-3) = 3");
    assert_eq(fixed_abs(a10), a10, "abs(10) = 10");
    assert_eq(fixed_abs(0), 0, "abs(0) = 0");

    # Lerp
    var half = FIXED_HALF;
    assert_eq(fixed_to_int(fixed_lerp(0, a10, half)), 5, "lerp(0,10,0.5) = 5");
    assert_eq(fixed_to_int(fixed_lerp(a10, a10, half)), 10, "lerp(10,10,0.5) = 10");

    # Approx distance
    var d = fixed_approx_dist(a3, fixed_from_int(4));
    assert(fixed_to_int(d) >= 4, "approx_dist(3,4) >= 4");
    assert(fixed_to_int(d) <= 6, "approx_dist(3,4) <= 6");

    # ============================================================
    test_group("trig tables");
    # ============================================================

    tables_init();

    # sin(0) = 0
    assert_eq(fixed_sin(0), 0, "sin(0) = 0");

    # sin(256) = sin(90°) = 1.0 = 65536
    assert_eq(fixed_sin(ANG90), 65536, "sin(90) = 1.0");

    # sin(512) = sin(180°) = 0
    assert_eq(fixed_sin(ANG180), 0, "sin(180) = 0");

    # cos(0) = 1.0
    assert_eq(fixed_cos(0), 65536, "cos(0) = 1.0");

    # cos(256) = cos(90°) = 0
    assert_eq(fixed_cos(ANG90), 0, "cos(90) = 0");

    # sin^2 + cos^2 ≈ 1 for angle 128 (45°)
    var s45 = fixed_sin(128);
    var c45 = fixed_cos(128);
    var sum_sq = fixed_mul(s45, s45) + fixed_mul(c45, c45);
    var sq_int = fixed_to_int(sum_sq);
    assert(sq_int >= 0, "sin^2+cos^2 >= 0");
    assert(sq_int <= 2, "sin^2+cos^2 <= 2");

    # ============================================================
    test_group("angle math");
    # ============================================================

    assert_eq(angle_normalize(0), 0, "norm(0)");
    assert_eq(angle_normalize(1024), 0, "norm(1024) wraps to 0");
    assert_eq(angle_normalize(1025), 1, "norm(1025) wraps to 1");
    assert_eq(angle_add(ANG270, ANG90), 0, "270+90 = 0 (wrap)");
    assert_eq(angle_sub(0, 1), ANG_MASK, "0-1 = 1023 (wrap)");

    # ============================================================
    test_group("fixed_atan2: full-range octants (RC-S4 regression)");
    # ============================================================
    # The octant coefficient must be 256 (a quadrant is 256 angle units, the
    # diagonal 128). With 128, outputs compressed to 0..64 / 192..256 and
    # jumped 64->192 as ay crossed ax — wrong sprite rotations, off-course
    # chase headings, snapping stereo pan.

    assert_eq(fixed_atan2(0, 65536), 0, "atan2(0,+x) = 0");
    assert_eq(fixed_atan2(65536, 0), ANG90, "atan2(+y,0) = ANG90");
    assert_eq(fixed_atan2(0, -65536), ANG180, "atan2(0,-x) = ANG180");
    assert_eq(fixed_atan2(-65536, 0), ANG270, "atan2(-y,0) = ANG270");
    assert_eq(fixed_atan2(65536, 65536), 128, "atan2(+y,+x) diagonal = 128 (was 64)");
    assert_eq(fixed_atan2(65536, -65536), 384, "atan2(+y,-x) diagonal = 384");
    assert_eq(fixed_atan2(-65536, -65536), 640, "atan2(-y,-x) diagonal = 640");
    assert_eq(fixed_atan2(-65536, 65536), 896, "atan2(-y,+x) diagonal = 896");
    var at_lo = fixed_atan2(65535, 65536);
    var at_hi = fixed_atan2(65537, 65536);
    assert(at_hi - at_lo >= 0, "atan2 monotonic across the diagonal");
    # The two octant branches truncate in opposite directions, so the seam is
    # up to 2 angle units (~0.7 deg) — vs the 128-unit (45 deg) jump pre-fix.
    assert(at_hi - at_lo <= 2, "atan2 continuous across the diagonal (was a 128-unit jump)");

    # ============================================================
    test_group("combat: RNG (p_random)");
    # ============================================================
    # Deterministic LCG: same seed reproduces the sequence; bytes stay 0..255.
    p_random_seed(0x13572468);
    var r0 = p_random();
    var r1 = p_random();
    assert(r0 >= 0 && r0 <= 255, "p_random in 0..255");
    assert(r1 >= 0 && r1 <= 255, "p_random in 0..255 (2)");
    p_random_seed(0x13572468);
    assert_eq(p_random(), r0, "p_random deterministic from seed");
    assert_eq(p_random(), r1, "p_random deterministic (2)");
    var pr_ok = 1;
    for (var ri = 0; ri < 64; ri += 1) {
        var pv = p_random_range(11);
        if (pv < 0) { pr_ok = 0; }
        if (pv > 10) { pr_ok = 0; }
    }
    assert_eq(pr_ok, 1, "p_random_range(11) stays in 0..10");

    # ============================================================
    test_group("combat: ammo (player_try_fire)");
    # ============================================================
    player_weapon = 2;            # pistol
    player_ammo_bullets = 3;
    assert_eq(player_try_fire(), 1, "pistol fires with ammo");
    assert_eq(player_ammo_bullets, 2, "pistol deducts 1 bullet");
    player_ammo_bullets = 0;
    assert_eq(player_try_fire(), 0, "pistol blocked when empty");
    assert_eq(player_ammo_bullets, 0, "no ammo underflow when empty");
    player_weapon = 1;            # fist
    assert_eq(player_try_fire(), 1, "fist always fires (no ammo)");

    # ============================================================
    test_group("combat: damage + state (thing_damage)");
    # ============================================================
    things = alloc(THING_MAX * THING_SIZE);
    thing_count = 0;
    var tb = things;                          # imp at (200,0), 60 hp, idle
    store64(tb, 200 << 16); store64(tb + 8, 0);
    store64(tb + 32, TTYPE_IMP); store64(tb + 40, STATE_SPAWN);
    store64(tb + 48, 60); store64(tb + 56, CAT_MONSTER);
    store64(tb + 80, 20 << 16);
    store64(tb + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE);
    store64(tb + 112, 0);
    thing_count = 1;

    thing_damage(0, 10);
    assert_eq(thing_health(0), 50, "imp 60-10 = 50 hp");
    assert(thing_state(0) != STATE_SPAWN, "shot wakes an idle monster");

    thing_damage(0, 100);
    assert_eq(thing_state(0), STATE_DIE, "lethal hit -> STATE_DIE");
    var hp_die = thing_health(0);
    thing_damage(0, 100);                     # corpse re-kill guard
    assert_eq(thing_state(0), STATE_DIE, "dying thing is not re-killed");
    assert_eq(thing_health(0), hp_die, "no further hp loss on a corpse");

    # ============================================================
    test_group("combat: hitscan select + LOS (player_fire_ray)");
    # ============================================================
    # No map loaded -> thing_check_sight finds no blockers (open field).
    thing_count = 0;
    var ah = things;                          # ahead at (+300,0)
    store64(ah, 300 << 16); store64(ah + 8, 0);
    store64(ah + 32, TTYPE_IMP); store64(ah + 40, STATE_SPAWN); store64(ah + 48, 100);
    store64(ah + 56, CAT_MONSTER); store64(ah + 80, 20 << 16);
    store64(ah + 104, TF_ACTIVE | TF_SHOOTABLE); store64(ah + 112, 0);
    var bh = things + THING_SIZE;              # behind at (-300,0)
    store64(bh, 0 - (300 << 16)); store64(bh + 8, 0);
    store64(bh + 32, TTYPE_IMP); store64(bh + 40, STATE_SPAWN); store64(bh + 48, 100);
    store64(bh + 56, CAT_MONSTER); store64(bh + 80, 20 << 16);
    store64(bh + 104, TF_ACTIVE | TF_SHOOTABLE); store64(bh + 112, 0);
    thing_count = 2;
    player_x = 0; player_y = 0; player_angle = 0;
    var hit = player_fire_ray(0, 2048 << 16, 10);
    assert_eq(hit, 0, "ray hits the monster ahead (idx 0)");
    assert_eq(thing_health(0), 90, "monster ahead took 10 dmg");
    assert_eq(thing_health(1), 100, "monster behind the player untouched");

    # ============================================================
    test_group("combat: splash + rocket projectile");
    # ============================================================
    thing_count = 0;
    var sb = things;                          # explosion source (barrel) at center
    store64(sb, 0); store64(sb + 8, 0);
    store64(sb + 32, TTYPE_BARREL); store64(sb + 40, STATE_DIE); store64(sb + 48, 0);
    store64(sb + 56, CAT_DECOR); store64(sb + 80, 10 << 16);
    store64(sb + 104, TF_ACTIVE); store64(sb + 112, 0);
    var s1 = things + THING_SIZE;             # near target, 16 units away
    store64(s1, 16 << 16); store64(s1 + 8, 0);
    store64(s1 + 32, TTYPE_IMP); store64(s1 + 40, STATE_SPAWN); store64(s1 + 48, 100);
    store64(s1 + 56, CAT_MONSTER); store64(s1 + 80, 20 << 16);
    store64(s1 + 104, TF_ACTIVE | TF_SHOOTABLE); store64(s1 + 112, 0);
    var s2 = things + 2 * THING_SIZE;         # far target, 100 units away
    store64(s2, 100 << 16); store64(s2 + 8, 0);
    store64(s2 + 32, TTYPE_IMP); store64(s2 + 40, STATE_SPAWN); store64(s2 + 48, 100);
    store64(s2 + 56, CAT_MONSTER); store64(s2 + 80, 20 << 16);
    store64(s2 + 104, TF_ACTIVE | TF_SHOOTABLE); store64(s2 + 112, 0);
    thing_count = 3;
    player_x = 0 - (4096 << 16); player_y = 0;   # keep the player out of range
    thing_explode(0, 128 << 16, 128);
    assert(thing_health(1) < 100, "explosion damages a nearby thing");
    assert(thing_health(2) < 100, "explosion reaches a farther thing");
    assert(thing_health(1) < thing_health(2), "splash falls off with distance");

    thing_count = 0;
    var m0 = things;                          # rocket target ahead at (+200,0)
    store64(m0, 200 << 16); store64(m0 + 8, 0);
    store64(m0 + 32, TTYPE_IMP); store64(m0 + 40, STATE_SPAWN); store64(m0 + 48, 200);
    store64(m0 + 56, CAT_MONSTER); store64(m0 + 80, 20 << 16);
    store64(m0 + 104, TF_ACTIVE | TF_SHOOTABLE); store64(m0 + 112, 0);
    thing_count = 1;
    player_x = 0; player_y = 0;
    var mi = thing_spawn_missile(0, 0, 0);
    assert(mi >= 0, "missile spawned");
    assert_eq(thing_category(mi), CAT_PROJECTILE, "missile is a projectile");
    assert((thing_flags(mi) & TF_MISSILE) != 0, "missile carries TF_MISSILE");
    var mguard = 0;
    while ((thing_flags(mi) & TF_ACTIVE) != 0 && mguard < 40) {
        thing_missile_tick(mi);
        mguard += 1;
    }
    assert((thing_flags(mi) & TF_ACTIVE) == 0, "missile detonated + freed its slot");
    assert(thing_health(0) < 200, "rocket splash damaged the target");

    # ============================================================
    test_group("combat: melee wind-up (F-G1 regression)");
    # ============================================================
    # A chasing monster in melee range with clear LOS must ARM a 15-tick
    # attack wind-up and NOT deal damage until it elapses. The F-G1 bug reset
    # tics to 0 the same tick the wind-up was set, so damage landed instantly
    # and repeated every ~2 ticks (~245 DPS instant kill). No map is loaded, so
    # thing_check_sight sees an open field (LOS clear).
    thing_count = 0;
    var mw = things;                          # imp 32 units ahead, already chasing
    store64(mw, 32 << 16); store64(mw + 8, 0);
    store64(mw + 32, TTYPE_IMP); store64(mw + 40, STATE_CHASE); store64(mw + 48, 60);
    store64(mw + 56, CAT_MONSTER); store64(mw + 80, 20 << 16);
    store64(mw + 96, 0);                       # tics = 0 on entry (as after SEE)
    store64(mw + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(mw + 112, 0);
    thing_count = 1;
    player_x = 0; player_y = 0; player_angle = 0;
    player_health = 100;

    thing_ai_tick(0);
    assert_eq(thing_state(0), STATE_ATTACK, "in-range chaser arms an attack");
    assert_eq(thing_tics(0), 15, "attack wind-up tics survive (not clobbered to 0)");
    assert_eq(player_health, 100, "no damage during the wind-up tick");

    # Tick the wind-up down: 15 decrement ticks bring tics 15->0, still no
    # damage; the tick that finds tics==0 is the one that deals the hit.
    var wt = 0;
    while (wt < 15) { thing_ai_tick(0); wt += 1; }
    assert_eq(player_health, 100, "no damage through the whole 15-tick wind-up");
    thing_ai_tick(0);                          # tics==0 now: damage lands, back to CHASE
    assert(player_health < 100, "damage lands once the wind-up elapses");
    assert(player_health >= 76, "single melee hit is 3-24 dmg, not an instant kill");

    # F-G4: chase movement is now collision-checked (player_check_position).
    # With no map loaded, collision passes everywhere, so a chaser must still
    # close distance on open ground — i.e. the new check must not freeze it.
    thing_count = 0;
    var mv = things;                          # imp 200 units ahead, chasing
    store64(mv, 200 << 16); store64(mv + 8, 0);
    store64(mv + 32, TTYPE_IMP); store64(mv + 40, STATE_CHASE); store64(mv + 48, 60);
    store64(mv + 56, CAT_MONSTER); store64(mv + 80, 20 << 16);
    store64(mv + 96, 0);
    store64(mv + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(mv + 112, 0);
    thing_count = 1;
    player_x = 0; player_y = 0; player_angle = 0; player_health = 100;
    var mx0 = thing_x(0);
    thing_ai_tick(0);
    assert(thing_x(0) < mx0, "chaser moves toward the player on open ground");
    assert(thing_x(0) > 190 << 16, "chaser steps ~1 unit/tick (not teleporting)");
    assert_eq(thing_state(0), STATE_CHASE, "still chasing (200u > attack range)");

    # ============================================================
    test_group("combat: spent barrel is not a bullet shield (F-G5)");
    # ============================================================
    # A detonated barrel used to keep TF_SHOOTABLE forever (its DIE->DEAD
    # transition lived in the monster-only AI path), so it absorbed every shot
    # aimed at the monster behind it. Barrel 50u ahead, monster 300u ahead
    # (out of the 128u splash radius) — after the barrel blows, a fired ray must
    # reach the monster.
    thing_count = 0;
    var bar = things;                         # barrel at (+50,0)
    store64(bar, 50 << 16); store64(bar + 8, 0);
    store64(bar + 32, TTYPE_BARREL); store64(bar + 40, STATE_SPAWN);
    store64(bar + 48, 20); store64(bar + 56, CAT_DECOR); store64(bar + 80, 10 << 16);
    store64(bar + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(bar + 112, 0);
    var beh = things + THING_SIZE;            # monster at (+300,0), past the splash
    store64(beh, 300 << 16); store64(beh + 8, 0);
    store64(beh + 32, TTYPE_IMP); store64(beh + 40, STATE_SPAWN); store64(beh + 48, 100);
    store64(beh + 56, CAT_MONSTER); store64(beh + 80, 20 << 16);
    store64(beh + 104, TF_ACTIVE | TF_SHOOTABLE); store64(beh + 112, 0);
    thing_count = 2;
    player_x = 0; player_y = 0; player_angle = 0; player_health = 100;

    thing_damage(0, 100);                     # blow the barrel
    assert_eq(thing_state(0), STATE_DIE, "shot barrel detonates -> STATE_DIE");
    assert((thing_flags(0) & TF_SHOOTABLE) == 0, "spent barrel drops TF_SHOOTABLE");
    assert_eq(thing_health(1), 100, "far monster took no splash (250u > 128u radius)");
    var bhit = player_fire_ray(0, 2048 << 16, 10);
    assert_eq(bhit, 1, "ray passes the spent barrel and hits the monster (idx 1)");
    assert_eq(thing_health(1), 90, "monster behind the barrel took the shot");

    # Decoration death still advances to an inert corpse (does not freeze).
    var bg = 0;
    while (thing_state(0) == STATE_DIE && bg < 20) { thing_ai_tick(0); bg += 1; }
    assert_eq(thing_state(0), STATE_DEAD, "spent barrel advances to an inert corpse");

    # ============================================================
    test_group("player: inventory carry across levels (F-G6)");
    # ============================================================
    # player_spawn_at_start (the level-advance path) repositions WITHOUT
    # touching inventory; player_init (new game / respawn) does a full reset.
    # Needs map_sectors + player_start allocated for the reposition path;
    # no BSP -> player_find_sector returns sector 0.
    map_sectors = alloc(MAP_MAX_SECTORS * MAP_SECTOR_SIZE);
    player_start = alloc(24);
    map_num_nodes = 0;

    player_init();
    assert_eq(player_weapons, 6, "player_init: pistol-start weapons (fist+pistol)");
    assert_eq(player_ammo_bullets, 50, "player_init: 50 bullets");
    # Earn some gear mid-episode.
    player_weapons = player_weapons | 8;      # shotgun
    player_ammo_shells = 20;
    player_health = 175;
    player_armor = 100;
    player_keys = KEY_CARD_BLUE;
    # Level advance keeps gear, resets per-level keys.
    player_spawn_at_start();
    player_keys = 0;                           # load_map(0) does this after spawn
    assert_eq(player_weapons, 14, "level advance keeps weapons (shotgun retained)");
    assert_eq(player_ammo_shells, 20, "level advance keeps shells");
    assert_eq(player_health, 175, "level advance keeps health");
    assert_eq(player_armor, 100, "level advance keeps armor");
    assert_eq(player_keys, 0, "keys are cleared per level");
    # A full reset (new game / respawn) does wipe back to pistol start.
    player_init();
    assert_eq(player_weapons, 6, "player_init wipes weapons back to pistol start");
    assert_eq(player_health, 100, "player_init resets health");

    # ============================================================
    test_group("sprite: rotation faces the viewer (F-R1)");
    # ============================================================
    # A monster facing the viewer must show its FRONT sprite (rotation 1). The
    # F-R1 bug omitted the ANG180 term, so a facing monster resolved to rot 5
    # (its back). Viewer at origin; thing 100u due east.
    view_x = 0; view_y = 0;
    assert_eq(sprite_calc_rotation(100 << 16, 0, ANG180), 1, "thing facing viewer -> front (rot 1)");
    assert_eq(sprite_calc_rotation(100 << 16, 0, 0), 5, "thing facing away -> back (rot 5)");
    assert_eq(sprite_calc_rotation(100 << 16, 0, ANG90), 3, "thing's left side toward viewer -> rot 3");

    # ============================================================
    test_group("pickups: health cap + no-pickup-at-full + ammo cap");
    # ============================================================
    player_x = 0; player_y = 0;
    # Stimpack on top of the player.
    thing_count = 0;
    var pk = things;
    store64(pk, 0); store64(pk + 8, 0);
    store64(pk + 32, TTYPE_STIMPACK); store64(pk + 104, TF_ACTIVE | TF_PICKUP);
    thing_count = 1;
    player_health = 100;
    things_check_pickups();
    assert_eq(player_health, 100, "stimpack does not over-heal past 100");
    assert((thing_flags(0) & TF_ACTIVE) != 0, "stimpack NOT consumed at full health");
    player_health = 95;
    things_check_pickups();
    assert_eq(player_health, 100, "stimpack heals to a max of 100 (95+10 clamped)");
    assert((thing_flags(0) & TF_ACTIVE) == 0, "stimpack consumed once it healed");
    # Medikit at 80 -> 100 (not 105, not 200).
    thing_count = 0;
    store64(pk, 0); store64(pk + 8, 0);
    store64(pk + 32, TTYPE_MEDIKIT); store64(pk + 104, TF_ACTIVE | TF_PICKUP);
    thing_count = 1;
    player_health = 80;
    things_check_pickups();
    assert_eq(player_health, 100, "medikit heals to a max of 100 (80+25 clamped)");
    # Ammo cap: clipbox (+50) over the 200 bullet ceiling clamps.
    thing_count = 0;
    store64(pk, 0); store64(pk + 8, 0);
    store64(pk + 32, TTYPE_CLIPBOX); store64(pk + 104, TF_ACTIVE | TF_PICKUP);
    thing_count = 1;
    player_ammo_bullets = 195;
    things_check_pickups();
    assert_eq(player_ammo_bullets, 200, "bullets capped at 200 (195+50 clamped)");

    # ============================================================
    test_group("collision: player vs solid things");
    # ============================================================
    # A solid thing (radius 10) 30u east; player radius 16 -> combined 26u.
    thing_count = 0;
    var so = things;
    store64(so, 30 << 16); store64(so + 8, 0);
    store64(so + 80, 10 << 16);                    # radius
    store64(so + 104, TF_ACTIVE | TF_SOLID);
    thing_count = 1;
    assert_eq(player_check_things(0, 0), 1, "30u away (>26) is clear of the solid thing");
    assert_eq(player_check_things(20 << 16, 0), 0, "10u away (<26) is blocked by the solid thing");
    # A corpse (TF_CORPSE, no SOLID) does not block.
    store64(so + 104, TF_ACTIVE | TF_CORPSE);
    assert_eq(player_check_things(20 << 16, 0), 1, "a corpse (non-solid) does not block");

    # ============================================================
    test_group("music: MUS synth voice (note-on -> tonal output)");
    # ============================================================
    # Exercise the synth directly (sequencer frozen via a large music_wait) so
    # it's WAD-free. A4 (MIDI 69, ~440 Hz) full volume on channel 0.
    music_init();
    music_playing = 1;
    music_wait = 1000000;              # freeze the sequencer (no score needed)
    music_note_on(0, 69, 127);
    var mactive = 0;
    for (var mv = 0; mv < MUSIC_VOICES; mv += 1) {
        if (load64(mv_state + mv * 8) != MV_FREE) { mactive += 1; }
    }
    assert_eq(mactive, 1, "note-on creates exactly one voice");
    var mpeak = 0; var mcross = 0; var mprev = 0;
    for (var mi = 0; mi < 2000; mi += 1) {
        var ms = music_render_sample();
        var ma = ms;
        if (ma < 0) { ma = 0 - ma; }
        if (ma > mpeak) { mpeak = ma; }
        if (mprev < 0) { if (ms >= 0) { mcross += 1; } }
        else { if (ms < 0) { mcross += 1; } }
        mprev = ms;
    }
    assert(mpeak > 0, "voice produces non-silent output");
    assert(mpeak < 32768, "output stays within S16 (no clip)");
    assert(mcross > 20, "output is tonal (A4 -> many zero-crossings)");
    # note-off releases the voice; env ramps to free.
    music_note_off(0, 69);
    var mg = 0;
    while (load64(mv_state) != MV_FREE && mg < 4000) { music_render_sample(); mg += 1; }
    assert_eq(load64(mv_state), MV_FREE, "note-off releases the voice");
    # Percussion (channel 15) is skipped in v1 — no voice.
    music_silence();
    music_note_on(15, 40, 127);
    var mperc = 0;
    for (var mp = 0; mp < MUSIC_VOICES; mp += 1) {
        if (load64(mv_state + mp * 8) != MV_FREE) { mperc += 1; }
    }
    assert_eq(mperc, 0, "percussion channel 15 takes no voice (v1)");

    # ============================================================
    # WAD tests require DOOM1.WAD — skip if not available
    # ============================================================

    var has_wad = 0;
    if (argc() > 1) {
        # v0.27.3 — wad_open now returns Result<i64, WadError>;
        # check the Ok tag instead of the legacy 0-on-success int.
        if (is_ok(wad_open(argv(1))) == 1) { has_wad = 1; }
    }

    if (has_wad == 1) {
        test_group("WAD parsing");

        assert_eq(wad_numlumps, 1264, "DOOM1.WAD has 1264 lumps");

        var pal = wad_find_lump("PLAYPAL");
        assert(pal >= 0, "PLAYPAL found");
        assert_eq(wad_lump_size(pal), 10752, "PLAYPAL size = 10752");

        var cmap = wad_find_lump("COLORMAP");
        assert(cmap >= 0, "COLORMAP found");
        assert_eq(wad_lump_size(cmap), 8704, "COLORMAP size = 8704");

        var tex1 = wad_find_lump("TEXTURE1");
        assert(tex1 >= 0, "TEXTURE1 found");

        var pnames = wad_find_lump("PNAMES");
        assert(pnames >= 0, "PNAMES found");

        var e1m1 = wad_find_lump("E1M1");
        assert(e1m1 >= 0, "E1M1 marker found");

        # ============================================================
        test_group("WAD lump read");
        # ============================================================

        var pd = wad_read_lump(pal);
        assert(pd != 0, "PLAYPAL data non-null");
        # Palette index 0 = black (0,0,0)
        assert_eq(load8(pd), 0, "pal[0].r = 0");
        assert_eq(load8(pd + 1), 0, "pal[0].g = 0");
        assert_eq(load8(pd + 2), 0, "pal[0].b = 0");
        # Palette index 4 = white (255,255,255)
        assert_eq(load8(pd + 12), 255, "pal[4].r = 255");

        # ============================================================
        test_group("map loading");
        # ============================================================

        framebuf_set_palette(pd);
        framebuf_init();

        assert_eq(map_load("E1M1"), 0, "E1M1 loads");
        assert_eq(map_num_vertexes, 467, "E1M1 vertexes = 467");
        assert_eq(map_num_linedefs, 475, "E1M1 linedefs = 475");
        assert_eq(map_num_sidedefs, 648, "E1M1 sidedefs = 648");
        assert_eq(map_num_sectors, 85, "E1M1 sectors = 85");
        assert_eq(map_num_segs, 732, "E1M1 segs = 732");
        assert_eq(map_num_ssectors, 237, "E1M1 subsectors = 237");
        assert_eq(map_num_nodes, 236, "E1M1 nodes = 236");
        assert_eq(map_num_things, 138, "E1M1 things = 138");

        # ============================================================
        test_group("player start");
        # ============================================================

        assert_eq(map_find_player_start(), 0, "player start found");
        assert_eq(fixed_to_int(player_start_x()), 1056, "start x = 1056");
        assert_eq(fixed_to_int(player_start_y()), 0 - 3616, "start y = -3616");

        # ============================================================
        test_group("sector data");
        # ============================================================

        # Sector 0 should have valid height data
        var fh = map_sector_floorh(0);
        var ch = map_sector_ceilh(0);
        assert(ch > fh, "ceil > floor for sector 0");

        var light = map_sector_light(0);
        assert(light >= 0, "light >= 0");
        assert(light <= 255, "light <= 255");

        # ============================================================
        test_group("texture loading");
        # ============================================================

        render_load_colormap();
        texture_init();

        var startan = texture_find("STARTAN3");
        assert(startan >= 0, "STARTAN3 found");
        assert_eq(texture_height(startan), 128, "STARTAN3 height = 128");

        var door3 = texture_find("DOOR3");
        assert(door3 >= 0, "DOOR3 found");

        # ============================================================
        test_group("COLORMAP");
        # ============================================================

        # Level 0 = full bright (identity map)
        assert_eq(render_shade(96, 0), 96, "shade(96, bright) = 96");
        # Level 31 = very dark
        var dark96 = render_shade(96, 31);
        assert(dark96 != 96, "shade(96, dark) != 96");
        # White stays white at full bright
        assert_eq(render_shade(4, 0), 4, "shade(white, bright) = white");

        # ============================================================
        test_group("collision (blockmap)");
        # ============================================================
        # Regression guard for the blockmap cell-index double-shift (latent
        # since 0.13.0, fixed 0.29.4): the buggy `fixed_to_int(asr(.,16))`
        # double-converted fixed->int (= asr 32), collapsing every query to
        # cell (0,0), so player_check_position returned 1 everywhere and the
        # player walked through all walls. A working system blocks SOMEWHERE on
        # a sweep through the spawn.
        player_init();
        assert_eq(player_check_position(player_x, player_y), 1, "spawn position is valid");
        var blk = 0;
        var sweep_d = 0 - (2048 << 16);
        while (sweep_d <= (2048 << 16)) {
            if (player_check_position(player_x + sweep_d, player_y) == 0) { blk = blk + 1; }
            if (player_check_position(player_x, player_y + sweep_d) == 0) { blk = blk + 1; }
            sweep_d = sweep_d + (64 << 16);
        }
        assert(blk > 0, "collision blocks on the spawn sweep (not walk-through-walls)");

        # ============================================================
        test_group("rendering");
        # ============================================================

        render_load_sky();
        sprite_init();

        # ============================================================
        test_group("sprite: lookup coverage (RC-S3 regression)");
        # ============================================================
        # These 12 types spawned and functioned but had no lookup entry, so
        # they rendered INVISIBLE (63 attacking spectres across E1M3-M9,
        # every shell/rocket box, powerups, corpse decor).

        var sp_l, sp_f = sprite_find_frame(58, 1, 0);
        assert(sp_l >= 0, "spectre (58) resolves a SARG lump");
        assert(sprite_find_lump(2049) >= 0, "shell box (2049) resolves SBOXA0");
        assert(sprite_find_lump(2046) >= 0, "rocket box (2046) resolves BROKA0");
        assert(sprite_find_lump(2010) >= 0, "rocket ammo (2010) resolves ROCKA0");
        assert(sprite_find_lump(8) >= 0, "backpack (8) resolves BPAKA0");
        assert(sprite_find_lump(24) >= 0, "blood pool (24) resolves POL5A0");
        assert(sprite_find_lump(35) >= 0, "candelabra (35) resolves CBRAA0");
        assert(sprite_find_lump(2024) >= 0, "blur sphere (2024) resolves PINSA0");
        assert(sprite_find_lump(2025) >= 0, "radsuit (2025) resolves SUITA0");
        var dp_l, dp_f = sprite_find_frame(15, 0, 13);
        assert(dp_l >= 0, "dead marine (15) frame N resolves PLAYN0");
        var gb_l, gb_f = sprite_find_frame(10, 0, 22);
        assert(gb_l >= 0, "gibbed marine (10) frame W resolves PLAYW0");

        view_x = player_start_x();
        view_y = player_start_y();
        view_angle = player_start_angle();

        render_frame();
        sprite_render_all();

        # Should have drawn most of the screen
        var nonzero = 0;
        for (var i = 0; i < 64000; i = i + 1) {
            if (load8(screen_buf + i) != 0) { nonzero = nonzero + 1; }
        }
        assert(nonzero > 20000, "rendered > 20000 non-black pixels");
        assert_eq(clip_count, 320, "all 320 columns clipped");

        wad_close();
    } else {
        syscall(1, 1, "(WAD tests skipped — pass WAD path as arg)\n", 44);
    }

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
