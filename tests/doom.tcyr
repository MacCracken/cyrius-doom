# doom.tcyr -- cyrius-doom test suite
# Run: cyrius test tests/doom.tcyr
#   or: cat tests/doom.tcyr | cc2 > build/test && chmod +x build/test && ./build/test wad/DOOM1.WAD

include "lib/string.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/fmt.cyr"
include "lib/io.cyr"
include "lib/args.cyr"
include "lib/assert.cyr"
include "lib/sakshi.cyr"

include "lib/bsp.cyr"
include "src/fixed.cyr"
include "src/tables.cyr"
include "src/wad.cyr"
# Wayland backend (v0.33.0) — framebuf.cyr/input.cyr reference win_*/present_mode
# in their #ifndef-AGNOS branches, so the (Linux) test build needs these too.
include "src/platform/wayland/wire.cyr"
include "src/platform/wayland/client.cyr"
include "src/platform/wayland/shm.cyr"
include "src/platform/window.cyr"
include "src/framebuf.cyr"
include "src/map.cyr"
include "src/texture.cyr"
include "src/render.cyr"
include "src/input.cyr"
include "src/player.cyr"
include "src/things.cyr"
include "src/sprite.cyr"
# doors.cyr included since the RC-G1/G3 regression tests exercise the real
# door thinkers + use-ray (its sound/level calls are stubbed below).
include "src/doors.cyr"
# music.cyr needs only SND_DMX_RATE from audio.cyr (not otherwise included here).
enum MusRateStub { SND_DMX_RATE = 11025; }
include "src/music.cyr"
# status.cyr included for the R-2 name-scratch regression (face/HUD-number lump
# lookup through the NUL-terminated 9-byte scratch). Self-contained: uses only
# wad_*/framebuf_*/player_* symbols already included above.
include "src/status.cyr"

# Hermetic no-op stubs for cross-module side-effects the combat path calls.
# sound.cyr / level.cyr / tick.cyr / doors.cyr aren't included here (they pull
# in device I/O and map state the unit tests don't want), so their symbols are
# otherwise undefined — and calling an undefined function jumps to an
# unresolved address and segfaults. Stubbing them keeps the test hermetic.
fn sound_pistol(): i64 { return 0; }
fn sound_shotgun(): i64 { return 0; }
fn sound_plasma(): i64 { return 0; }
fn sound_explode(): i64 { return 0; }
fn sound_weapon_dry(): i64 { return 0; }
fn sound_player_pain(): i64 { return 0; }
fn sound_monster_pain(): i64 { return 0; }
fn sound_monster_die(): i64 { return 0; }
fn sound_item_pickup(): i64 { return 0; }
fn audio_play_name(lump_name): i64 { return 0; }
fn audio_play_at(lump_name, sx, sy): i64 { return 0; }
fn level_add_kill(): i64 { return 0; }
fn level_add_item(): i64 { return 0; }
fn tick_get_count(): i64 { return 0; }
fn sound_door_open(): i64 { return 0; }
fn level_exit_normal(): i64 { return 0; }
fn level_exit_secret(): i64 { return 0; }

fn main() {
    alloc_init();
    args_init();

    # ============================================================
    test_group("asr (arithmetic shift right)");
    # ============================================================

    assert_eq(asr(256, 4), 16, "asr(256,4) = 16");
    assert_eq(asr(0, 8), 0, "asr(0,8) = 0");
    assert_eq(asr(1, 0), 1, "asr(1,0) = 1");

    # Negative values — the critical case
    var neg100 = 0 - 100;
    assert_eq(asr(neg100, 1), 0 - 50, "asr(-100,1) = -50");
    assert_eq(asr(neg100, 2), 0 - 25, "asr(-100,2) = -25");

    # ============================================================
    test_group("fixed-point conversion");
    # ============================================================

    assert_eq(fixed_from_int(0), 0, "from_int(0)");
    assert_eq(fixed_from_int(1), 65536, "from_int(1)");
    assert_eq(fixed_from_int(100), 6553600, "from_int(100)");

    assert_eq(fixed_to_int(65536), 1, "to_int(1.0)");
    assert_eq(fixed_to_int(131072), 2, "to_int(2.0)");
    assert_eq(fixed_to_int(0), 0, "to_int(0)");

    # Negative round-trip
    var neg5 = fixed_from_int(0 - 5);
    assert_eq(fixed_to_int(neg5), 0 - 5, "to_int(from_int(-5)) = -5");
    var neg1000 = fixed_from_int(0 - 1000);
    assert_eq(fixed_to_int(neg1000), 0 - 1000, "to_int(from_int(-1000)) = -1000");

    # ============================================================
    test_group("fixed-point arithmetic");
    # ============================================================

    var a10 = fixed_from_int(10);
    var a3 = fixed_from_int(3);

    assert_eq(fixed_to_int(fixed_mul(a10, a3)), 30, "10*3 = 30");
    assert_eq(fixed_to_int(fixed_div(a10, a3)), 3, "10/3 = 3 (trunc)");
    assert_eq(fixed_div(a10, 0), FIXED_MAX, "div by zero = MAX");

    # Negative multiplication
    var neg3 = fixed_from_int(0 - 3);
    assert_eq(fixed_to_int(fixed_mul(a10, neg3)), 0 - 30, "10 * -3 = -30");
    assert_eq(fixed_to_int(fixed_mul(neg3, neg3)), 9, "-3 * -3 = 9");

    # Abs
    assert_eq(fixed_abs(neg3), a3, "abs(-3) = 3");
    assert_eq(fixed_abs(a10), a10, "abs(10) = 10");
    assert_eq(fixed_abs(0), 0, "abs(0) = 0");

    # Lerp
    var half = FIXED_HALF;
    assert_eq(fixed_to_int(fixed_lerp(0, a10, half)), 5, "lerp(0,10,0.5) = 5");
    assert_eq(fixed_to_int(fixed_lerp(a10, a10, half)), 10, "lerp(10,10,0.5) = 10");

    # Approx distance
    var d = fixed_approx_dist(a3, fixed_from_int(4));
    assert(fixed_to_int(d) >= 4, "approx_dist(3,4) >= 4");
    assert(fixed_to_int(d) <= 6, "approx_dist(3,4) <= 6");

    # ============================================================
    test_group("trig tables");
    # ============================================================

    tables_init();

    # sin(0) = 0
    assert_eq(fixed_sin(0), 0, "sin(0) = 0");

    # sin(256) = sin(90°) = 1.0 = 65536
    assert_eq(fixed_sin(ANG90), 65536, "sin(90) = 1.0");

    # sin(512) = sin(180°) = 0
    assert_eq(fixed_sin(ANG180), 0, "sin(180) = 0");

    # cos(0) = 1.0
    assert_eq(fixed_cos(0), 65536, "cos(0) = 1.0");

    # cos(256) = cos(90°) = 0
    assert_eq(fixed_cos(ANG90), 0, "cos(90) = 0");

    # sin^2 + cos^2 ≈ 1 for angle 128 (45°)
    var s45 = fixed_sin(128);
    var c45 = fixed_cos(128);
    var sum_sq = fixed_mul(s45, s45) + fixed_mul(c45, c45);
    var sq_int = fixed_to_int(sum_sq);
    assert(sq_int >= 0, "sin^2+cos^2 >= 0");
    assert(sq_int <= 2, "sin^2+cos^2 <= 2");

    # ============================================================
    test_group("angle math");
    # ============================================================

    assert_eq(angle_normalize(0), 0, "norm(0)");
    assert_eq(angle_normalize(1024), 0, "norm(1024) wraps to 0");
    assert_eq(angle_normalize(1025), 1, "norm(1025) wraps to 1");
    assert_eq(angle_add(ANG270, ANG90), 0, "270+90 = 0 (wrap)");
    assert_eq(angle_sub(0, 1), ANG_MASK, "0-1 = 1023 (wrap)");

    # ============================================================
    test_group("fixed_atan2: full-range octants (RC-S4 regression)");
    # ============================================================
    # The octant coefficient must be 256 (a quadrant is 256 angle units, the
    # diagonal 128). With 128, outputs compressed to 0..64 / 192..256 and
    # jumped 64->192 as ay crossed ax — wrong sprite rotations, off-course
    # chase headings, snapping stereo pan.

    assert_eq(fixed_atan2(0, 65536), 0, "atan2(0,+x) = 0");
    assert_eq(fixed_atan2(65536, 0), ANG90, "atan2(+y,0) = ANG90");
    assert_eq(fixed_atan2(0, -65536), ANG180, "atan2(0,-x) = ANG180");
    assert_eq(fixed_atan2(-65536, 0), ANG270, "atan2(-y,0) = ANG270");
    assert_eq(fixed_atan2(65536, 65536), 128, "atan2(+y,+x) diagonal = 128 (was 64)");
    assert_eq(fixed_atan2(65536, -65536), 384, "atan2(+y,-x) diagonal = 384");
    assert_eq(fixed_atan2(-65536, -65536), 640, "atan2(-y,-x) diagonal = 640");
    assert_eq(fixed_atan2(-65536, 65536), 896, "atan2(-y,+x) diagonal = 896");
    var at_lo = fixed_atan2(65535, 65536);
    var at_hi = fixed_atan2(65537, 65536);
    assert(at_hi - at_lo >= 0, "atan2 monotonic across the diagonal");
    # The two octant branches truncate in opposite directions, so the seam is
    # up to 2 angle units (~0.7 deg) — vs the 128-unit (45 deg) jump pre-fix.
    assert(at_hi - at_lo <= 2, "atan2 continuous across the diagonal (was a 128-unit jump)");

    # ============================================================
    test_group("fixed_atan2: minimax accuracy (0.33.1)");
    # ============================================================
    # The diamond-angle approximation was off by up to ~11 units (~3.9 deg)
    # mid-octant: exact-aim hitscan rays whiffed 20-unit-radius monsters past
    # ~350 units (lateral error grows with range — the "shots don't register"
    # component of the 0.33.0 field report) and chase headings wobbled. The
    # quadratic minimax octant atan is within ~1 unit everywhere.
    # Ground truth: atan2(399,-116) = 106.20 deg = 302.1 units (diamond: 313).
    var aa = fixed_atan2(399 << 16, 0 - (116 << 16));
    assert(aa >= 301, "atan2(399,-116) >= 301 (true 302; diamond gave 313)");
    assert(aa <= 303, "atan2(399,-116) <= 303");
    # atan(1/2) = 26.57 deg = 75.6 units.
    var ab = fixed_atan2(1 << 16, 2 << 16);
    assert(ab >= 75, "atan2(1,2) >= 75 (true 75.6)");
    assert(ab <= 76, "atan2(1,2) <= 76");
    # atan(1/5) = 11.31 deg = 32.2 units.
    var ac = fixed_atan2(1 << 16, 5 << 16);
    assert(ac >= 31, "atan2(1,5) >= 31 (true 32.2)");
    assert(ac <= 33, "atan2(1,5) <= 33");

    # ============================================================
    test_group("sky: world-anchored U mapping (0.33.1)");
    # ============================================================
    # x_to_viewangle = projection-matched per-column view-angle offsets
    # (vanilla xtoviewangle): +45 deg at col 0, 0 at center, -45 deg at 319.
    assert_eq(load64(x_to_viewangle), 128, "col 0 offset = +128 units (+45 deg)");
    assert_eq(load64(x_to_viewangle + 160 * 8), 0, "center col offset = 0");
    var e319 = load64(x_to_viewangle + 319 * 8);
    assert(e319 <= 0 - 126, "col 319 offset <= -126 (~-45 deg)");
    assert(e319 >= 0 - 128, "col 319 offset >= -128");
    # Wrap: +256 view-angle units (90 deg) = exactly one 256-wide sky width
    # at DOOM's 4-wraps-per-turn rate.
    view_angle = 100;
    var u80 = render_sky_u(80, 256);
    view_angle = 356;
    assert_eq(render_sky_u(80, 256), u80, "sky U invariant under va+256 (wrap)");
    # World anchoring: U depends only on va + x_to_viewangle[col], so the sky
    # texel under a fixed WORLD direction stays put as the view turns. The
    # old linear col term panned sky features AGAINST the wall projection
    # ("mountains move with the view", 0.33.0 field report).
    var o60 = load64(x_to_viewangle + 60 * 8);
    var o250 = load64(x_to_viewangle + 250 * 8);
    view_angle = 100;
    var u60 = render_sky_u(60, 256);
    view_angle = 100 + o60 - o250;
    assert_eq(render_sky_u(250, 256), u60, "sky U world-anchored across a turn");
    view_angle = 0;

    # ============================================================
    test_group("combat: RNG (p_random)");
    # ============================================================
    # Deterministic LCG: same seed reproduces the sequence; bytes stay 0..255.
    p_random_seed(0x13572468);
    var r0 = p_random();
    var r1 = p_random();
    assert(r0 >= 0 && r0 <= 255, "p_random in 0..255");
    assert(r1 >= 0 && r1 <= 255, "p_random in 0..255 (2)");
    p_random_seed(0x13572468);
    assert_eq(p_random(), r0, "p_random deterministic from seed");
    assert_eq(p_random(), r1, "p_random deterministic (2)");
    var pr_ok = 1;
    for (var ri = 0; ri < 64; ri += 1) {
        var pv = p_random_range(11);
        if (pv < 0) { pr_ok = 0; }
        if (pv > 10) { pr_ok = 0; }
    }
    assert_eq(pr_ok, 1, "p_random_range(11) stays in 0..10");

    # ============================================================
    test_group("combat: ammo (player_try_fire)");
    # ============================================================
    player_weapon = 2;            # pistol
    player_ammo_bullets = 3;
    assert_eq(player_try_fire(), 1, "pistol fires with ammo");
    assert_eq(player_ammo_bullets, 2, "pistol deducts 1 bullet");
    player_ammo_bullets = 0;
    assert_eq(player_try_fire(), 0, "pistol blocked when empty");
    assert_eq(player_ammo_bullets, 0, "no ammo underflow when empty");
    player_weapon = 1;            # fist
    assert_eq(player_try_fire(), 1, "fist always fires (no ammo)");

    # ============================================================
    test_group("combat: damage + state (thing_damage)");
    # ============================================================
    things = alloc(THING_MAX * THING_SIZE);
    thing_count = 0;
    var tb = things;                          # imp at (200,0), 60 hp, idle
    store64(tb, 200 << 16); store64(tb + 8, 0);
    store64(tb + 32, TTYPE_IMP); store64(tb + 40, STATE_SPAWN);
    store64(tb + 48, 60); store64(tb + 56, CAT_MONSTER);
    store64(tb + 80, 20 << 16);
    store64(tb + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE);
    store64(tb + 112, 0);
    thing_count = 1;

    thing_damage(0, 10);
    assert_eq(thing_health(0), 50, "imp 60-10 = 50 hp");
    assert(thing_state(0) != STATE_SPAWN, "shot wakes an idle monster");

    thing_damage(0, 100);
    assert_eq(thing_state(0), STATE_DIE, "lethal hit -> STATE_DIE");
    var hp_die = thing_health(0);
    thing_damage(0, 100);                     # corpse re-kill guard
    assert_eq(thing_state(0), STATE_DIE, "dying thing is not re-killed");
    assert_eq(thing_health(0), hp_die, "no further hp loss on a corpse");

    # ============================================================
    test_group("combat: hitscan select + LOS (player_fire_ray)");
    # ============================================================
    # No map loaded -> thing_check_sight finds no blockers (open field).
    thing_count = 0;
    var ah = things;                          # ahead at (+300,0)
    store64(ah, 300 << 16); store64(ah + 8, 0);
    store64(ah + 32, TTYPE_IMP); store64(ah + 40, STATE_SPAWN); store64(ah + 48, 100);
    store64(ah + 56, CAT_MONSTER); store64(ah + 80, 20 << 16);
    store64(ah + 104, TF_ACTIVE | TF_SHOOTABLE); store64(ah + 112, 0);
    var bh = things + THING_SIZE;              # behind at (-300,0)
    store64(bh, 0 - (300 << 16)); store64(bh + 8, 0);
    store64(bh + 32, TTYPE_IMP); store64(bh + 40, STATE_SPAWN); store64(bh + 48, 100);
    store64(bh + 56, CAT_MONSTER); store64(bh + 80, 20 << 16);
    store64(bh + 104, TF_ACTIVE | TF_SHOOTABLE); store64(bh + 112, 0);
    thing_count = 2;
    player_x = 0; player_y = 0; player_angle = 0;
    var hit = player_fire_ray(0, 2048 << 16, 10);
    assert_eq(hit, 0, "ray hits the monster ahead (idx 0)");
    assert_eq(thing_health(0), 90, "monster ahead took 10 dmg");
    assert_eq(thing_health(1), 100, "monster behind the player untouched");

    # ============================================================
    test_group("combat: splash + rocket projectile");
    # ============================================================
    thing_count = 0;
    var sb = things;                          # explosion source (barrel) at center
    store64(sb, 0); store64(sb + 8, 0);
    store64(sb + 32, TTYPE_BARREL); store64(sb + 40, STATE_DIE); store64(sb + 48, 0);
    store64(sb + 56, CAT_DECOR); store64(sb + 80, 10 << 16);
    store64(sb + 104, TF_ACTIVE); store64(sb + 112, 0);
    var s1 = things + THING_SIZE;             # near target, 16 units away
    store64(s1, 16 << 16); store64(s1 + 8, 0);
    store64(s1 + 32, TTYPE_IMP); store64(s1 + 40, STATE_SPAWN); store64(s1 + 48, 100);
    store64(s1 + 56, CAT_MONSTER); store64(s1 + 80, 20 << 16);
    store64(s1 + 104, TF_ACTIVE | TF_SHOOTABLE); store64(s1 + 112, 0);
    var s2 = things + 2 * THING_SIZE;         # far target, 100 units away
    store64(s2, 100 << 16); store64(s2 + 8, 0);
    store64(s2 + 32, TTYPE_IMP); store64(s2 + 40, STATE_SPAWN); store64(s2 + 48, 100);
    store64(s2 + 56, CAT_MONSTER); store64(s2 + 80, 20 << 16);
    store64(s2 + 104, TF_ACTIVE | TF_SHOOTABLE); store64(s2 + 112, 0);
    thing_count = 3;
    player_x = 0 - (4096 << 16); player_y = 0;   # keep the player out of range
    thing_explode(0, 128 << 16, 128);
    assert(thing_health(1) < 100, "explosion damages a nearby thing");
    assert(thing_health(2) < 100, "explosion reaches a farther thing");
    assert(thing_health(1) < thing_health(2), "splash falls off with distance");

    thing_count = 0;
    var m0 = things;                          # rocket target ahead at (+200,0)
    store64(m0, 200 << 16); store64(m0 + 8, 0);
    store64(m0 + 32, TTYPE_IMP); store64(m0 + 40, STATE_SPAWN); store64(m0 + 48, 200);
    store64(m0 + 56, CAT_MONSTER); store64(m0 + 80, 20 << 16);
    store64(m0 + 104, TF_ACTIVE | TF_SHOOTABLE); store64(m0 + 112, 0);
    thing_count = 1;
    player_x = 0; player_y = 0;
    var mi = thing_spawn_missile(0, 0, 0);
    assert(mi >= 0, "missile spawned");
    assert_eq(thing_category(mi), CAT_PROJECTILE, "missile is a projectile");
    assert((thing_flags(mi) & TF_MISSILE) != 0, "missile carries TF_MISSILE");
    var mguard = 0;
    while ((thing_flags(mi) & TF_ACTIVE) != 0 && mguard < 40) {
        thing_missile_tick(mi);
        mguard += 1;
    }
    assert((thing_flags(mi) & TF_ACTIVE) == 0, "missile detonated + freed its slot");
    assert(thing_health(0) < 200, "rocket splash damaged the target");

    # ============================================================
    test_group("combat: melee wind-up (F-G1 regression)");
    # ============================================================
    # A chasing monster in melee range with clear LOS must ARM a 15-tick
    # attack wind-up and NOT deal damage until it elapses. The F-G1 bug reset
    # tics to 0 the same tick the wind-up was set, so damage landed instantly
    # and repeated every ~2 ticks (~245 DPS instant kill). No map is loaded, so
    # thing_check_sight sees an open field (LOS clear).
    thing_count = 0;
    var mw = things;                          # imp 32 units ahead, already chasing
    store64(mw, 32 << 16); store64(mw + 8, 0);
    store64(mw + 32, TTYPE_IMP); store64(mw + 40, STATE_CHASE); store64(mw + 48, 60);
    store64(mw + 56, CAT_MONSTER); store64(mw + 80, 20 << 16);
    store64(mw + 96, 0);                       # tics = 0 on entry (as after SEE)
    store64(mw + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(mw + 112, 0);
    thing_count = 1;
    player_x = 0; player_y = 0; player_angle = 0;
    player_health = 100;

    thing_ai_tick(0);
    assert_eq(thing_state(0), STATE_ATTACK, "in-range chaser arms an attack");
    assert_eq(thing_tics(0), 15, "attack wind-up tics survive (not clobbered to 0)");
    assert_eq(player_health, 100, "no damage during the wind-up tick");

    # Tick the wind-up down: 15 decrement ticks bring tics 15->0, still no
    # damage; the tick that finds tics==0 is the one that deals the hit.
    var wt = 0;
    while (wt < 15) { thing_ai_tick(0); wt += 1; }
    assert_eq(player_health, 100, "no damage through the whole 15-tick wind-up");
    thing_ai_tick(0);                          # tics==0 now: damage lands, back to CHASE
    assert(player_health < 100, "damage lands once the wind-up elapses");
    assert(player_health >= 76, "single melee hit is 3-24 dmg, not an instant kill");

    # F-G4: chase movement is now collision-checked (player_check_position).
    # With no map loaded, collision passes everywhere, so a chaser must still
    # close distance on open ground — i.e. the new check must not freeze it.
    thing_count = 0;
    var mv = things;                          # imp 200 units ahead, chasing
    store64(mv, 200 << 16); store64(mv + 8, 0);
    store64(mv + 32, TTYPE_IMP); store64(mv + 40, STATE_CHASE); store64(mv + 48, 60);
    store64(mv + 56, CAT_MONSTER); store64(mv + 80, 20 << 16);
    store64(mv + 96, 0);
    store64(mv + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(mv + 112, 0);
    thing_count = 1;
    player_x = 0; player_y = 0; player_angle = 0; player_health = 100;
    var mx0 = thing_x(0);
    thing_ai_tick(0);
    assert(thing_x(0) < mx0, "chaser moves toward the player on open ground");
    assert(thing_x(0) > 190 << 16, "chaser steps ~1 unit/tick (not teleporting)");
    assert_eq(thing_state(0), STATE_CHASE, "still chasing (200u > attack range)");

    # ============================================================
    test_group("combat: ranged attacks (0.33.1)");
    # ============================================================
    # Monsters used to have ONLY melee (attack armed under 64 units): any
    # enemy that couldn't path to the player stood inert forever — the
    # "enemies not reactionary" field report. Zombiemen now hitscan and
    # imps throw BAL1 fireballs, vanilla-style (distance-rolled arm, LOS
    # re-check at release, cooldown in aux).
    p_random_seed(0x13572468);
    thing_count = 0;
    var rz = things;                          # zombieman 600 units east
    store64(rz, 600 << 16); store64(rz + 8, 0);
    store64(rz + 32, TTYPE_ZOMBIEMAN); store64(rz + 40, STATE_CHASE); store64(rz + 48, 20);
    store64(rz + 56, CAT_MONSTER); store64(rz + 80, 20 << 16);
    store64(rz + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(rz + 112, 0);
    store64(rz + 120, 0);
    thing_count = 1;
    player_x = 0; player_y = 0; player_health = 100; player_armor = 0;
    for (var rt = 0; rt < 400; rt += 1) { things_tick(); }
    # 400 ticks closes at most ~400 units: still 200+ away, melee impossible.
    assert(player_health < 100, "zombieman hitscans at range (was melee-only stasis)");

    p_random_seed(0x13572468);
    thing_count = 0;
    var ri = things;                          # imp 600 units east
    store64(ri, 600 << 16); store64(ri + 8, 0);
    store64(ri + 32, TTYPE_IMP); store64(ri + 40, STATE_CHASE); store64(ri + 48, 60);
    store64(ri + 56, CAT_MONSTER); store64(ri + 80, 20 << 16);
    store64(ri + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(ri + 112, 0);
    store64(ri + 120, 0);
    thing_count = 1;
    player_x = 0; player_y = 0; player_health = 100; player_armor = 0;
    var saw_ball = 0;
    for (var rt2 = 0; rt2 < 400; rt2 += 1) {
        things_tick();
        for (var rb = 0; rb < thing_count; rb += 1) {
            if (thing_type(rb) == TTYPE_IMP_FIREBALL) {
                if ((thing_flags(rb) & TF_ACTIVE) != 0) { saw_ball = 1; }
            }
        }
    }
    assert_eq(saw_ball, 1, "imp throws a BAL1 fireball (projectile spawned in flight)");
    assert(player_health < 100, "imp fireball connects (owner-immune, hits the player)");

    # Melee-only monsters gained nothing: a demon at range stays quiet.
    p_random_seed(0x13572468);
    thing_count = 0;
    var rd = things;
    store64(rd, 600 << 16); store64(rd + 8, 0);
    store64(rd + 32, TTYPE_DEMON); store64(rd + 40, STATE_CHASE); store64(rd + 48, 150);
    store64(rd + 56, CAT_MONSTER); store64(rd + 80, 30 << 16);
    store64(rd + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(rd + 112, 0);
    store64(rd + 120, 0);
    thing_count = 1;
    player_x = 0; player_y = 0; player_health = 100; player_armor = 0;
    for (var rt3 = 0; rt3 < 300; rt3 += 1) { things_tick(); }
    assert_eq(player_health, 100, "demon (melee-only) cannot hurt from 300+ units");
    thing_count = 0;

    # ============================================================
    test_group("combat: spent barrel is not a bullet shield (F-G5)");
    # ============================================================
    # A detonated barrel used to keep TF_SHOOTABLE forever (its DIE->DEAD
    # transition lived in the monster-only AI path), so it absorbed every shot
    # aimed at the monster behind it. Barrel 50u ahead, monster 300u ahead
    # (out of the 128u splash radius) — after the barrel blows, a fired ray must
    # reach the monster.
    thing_count = 0;
    var bar = things;                         # barrel at (+50,0)
    store64(bar, 50 << 16); store64(bar + 8, 0);
    store64(bar + 32, TTYPE_BARREL); store64(bar + 40, STATE_SPAWN);
    store64(bar + 48, 20); store64(bar + 56, CAT_DECOR); store64(bar + 80, 10 << 16);
    store64(bar + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(bar + 112, 0);
    var beh = things + THING_SIZE;            # monster at (+300,0), past the splash
    store64(beh, 300 << 16); store64(beh + 8, 0);
    store64(beh + 32, TTYPE_IMP); store64(beh + 40, STATE_SPAWN); store64(beh + 48, 100);
    store64(beh + 56, CAT_MONSTER); store64(beh + 80, 20 << 16);
    store64(beh + 104, TF_ACTIVE | TF_SHOOTABLE); store64(beh + 112, 0);
    thing_count = 2;
    player_x = 0; player_y = 0; player_angle = 0; player_health = 100;

    thing_damage(0, 100);                     # blow the barrel
    assert_eq(thing_state(0), STATE_DIE, "shot barrel detonates -> STATE_DIE");
    assert((thing_flags(0) & TF_SHOOTABLE) == 0, "spent barrel drops TF_SHOOTABLE");
    assert_eq(thing_health(1), 100, "far monster took no splash (250u > 128u radius)");
    var bhit = player_fire_ray(0, 2048 << 16, 10);
    assert_eq(bhit, 1, "ray passes the spent barrel and hits the monster (idx 1)");
    assert_eq(thing_health(1), 90, "monster behind the barrel took the shot");

    # Decoration death still advances to an inert corpse (does not freeze).
    var bg = 0;
    while (thing_state(0) == STATE_DIE && bg < 20) { thing_ai_tick(0); bg += 1; }
    assert_eq(thing_state(0), STATE_DEAD, "spent barrel advances to an inert corpse");

    # ============================================================
    test_group("player: inventory carry across levels (F-G6)");
    # ============================================================
    # player_spawn_at_start (the level-advance path) repositions WITHOUT
    # touching inventory; player_init (new game / respawn) does a full reset.
    # Needs map_sectors + player_start allocated for the reposition path;
    # no BSP -> player_find_sector returns sector 0.
    map_sectors = alloc(MAP_MAX_SECTORS * MAP_SECTOR_SIZE);
    player_start = alloc(24);
    map_num_nodes = 0;

    player_init();
    assert_eq(player_weapons, 6, "player_init: pistol-start weapons (fist+pistol)");
    assert_eq(player_ammo_bullets, 50, "player_init: 50 bullets");
    # Earn some gear mid-episode.
    player_weapons = player_weapons | 8;      # shotgun
    player_ammo_shells = 20;
    player_health = 175;
    player_armor = 100;
    player_keys = KEY_CARD_BLUE;
    # Level advance keeps gear, resets per-level keys.
    player_spawn_at_start();
    player_keys = 0;                           # load_map(0) does this after spawn
    assert_eq(player_weapons, 14, "level advance keeps weapons (shotgun retained)");
    assert_eq(player_ammo_shells, 20, "level advance keeps shells");
    assert_eq(player_health, 175, "level advance keeps health");
    assert_eq(player_armor, 100, "level advance keeps armor");
    assert_eq(player_keys, 0, "keys are cleared per level");
    # A full reset (new game / respawn) does wipe back to pistol start.
    player_init();
    assert_eq(player_weapons, 6, "player_init wipes weapons back to pistol start");
    assert_eq(player_health, 100, "player_init resets health");

    # ============================================================
    test_group("sprite: rotation faces the viewer (F-R1)");
    # ============================================================
    # A monster facing the viewer must show its FRONT sprite (rotation 1). The
    # F-R1 bug omitted the ANG180 term, so a facing monster resolved to rot 5
    # (its back). Viewer at origin; thing 100u due east.
    view_x = 0; view_y = 0;
    assert_eq(sprite_calc_rotation(100 << 16, 0, ANG180), 1, "thing facing viewer -> front (rot 1)");
    assert_eq(sprite_calc_rotation(100 << 16, 0, 0), 5, "thing facing away -> back (rot 5)");
    assert_eq(sprite_calc_rotation(100 << 16, 0, ANG90), 3, "thing's left side toward viewer -> rot 3");

    # ============================================================
    test_group("pickups: health cap + no-pickup-at-full + ammo cap");
    # ============================================================
    player_x = 0; player_y = 0;
    # Stimpack on top of the player.
    thing_count = 0;
    var pk = things;
    store64(pk, 0); store64(pk + 8, 0);
    store64(pk + 32, TTYPE_STIMPACK); store64(pk + 104, TF_ACTIVE | TF_PICKUP);
    thing_count = 1;
    player_health = 100;
    things_check_pickups();
    assert_eq(player_health, 100, "stimpack does not over-heal past 100");
    assert((thing_flags(0) & TF_ACTIVE) != 0, "stimpack NOT consumed at full health");
    player_health = 95;
    things_check_pickups();
    assert_eq(player_health, 100, "stimpack heals to a max of 100 (95+10 clamped)");
    assert((thing_flags(0) & TF_ACTIVE) == 0, "stimpack consumed once it healed");
    # Medikit at 80 -> 100 (not 105, not 200).
    thing_count = 0;
    store64(pk, 0); store64(pk + 8, 0);
    store64(pk + 32, TTYPE_MEDIKIT); store64(pk + 104, TF_ACTIVE | TF_PICKUP);
    thing_count = 1;
    player_health = 80;
    things_check_pickups();
    assert_eq(player_health, 100, "medikit heals to a max of 100 (80+25 clamped)");
    # Ammo cap: clipbox (+50) over the 200 bullet ceiling clamps.
    thing_count = 0;
    store64(pk, 0); store64(pk + 8, 0);
    store64(pk + 32, TTYPE_CLIPBOX); store64(pk + 104, TF_ACTIVE | TF_PICKUP);
    thing_count = 1;
    player_ammo_bullets = 195;
    things_check_pickups();
    assert_eq(player_ammo_bullets, 200, "bullets capped at 200 (195+50 clamped)");

    # ============================================================
    test_group("armor: class fixes absorption fraction (G-4)");
    # ============================================================
    # Blue armor keeps 1/2 absorption for its whole life; the old count-based test
    # (player_armor>100) silently degraded a depleting blue set to green 1/3 <100.
    thing_count = 0;
    store64(pk, 0); store64(pk + 8, 0);
    store64(pk + 32, TTYPE_ARMOR_BLUE); store64(pk + 104, TF_ACTIVE | TF_PICKUP);
    thing_count = 1;
    player_armor = 0; player_armor_class = 0; player_health = 100;
    things_check_pickups();
    assert_eq(player_armor, 200, "blue armor pickup sets armor 200");
    assert_eq(player_armor_class, 2, "blue armor pickup sets class 2");
    player_armor = 90;                      # drained below 100 — count-based would flip to 1/3
    player_take_damage(30);                 # class 2 → absorb 15
    assert_eq(player_armor, 75, "blue absorbs 1/2 below 100 (90-15)");
    assert_eq(player_health, 85, "blue: only 15 of 30 reached health");
    player_armor = 60; player_armor_class = 1; player_health = 100;
    player_take_damage(30);                 # class 1 (green) → absorb 10
    assert_eq(player_armor, 50, "green absorbs 1/3 (60-10)");
    assert_eq(player_health, 80, "green: 20 of 30 reached health");
    player_armor = 5; player_armor_class = 2; player_health = 100;
    player_take_damage(40);                 # absorb min(20,5)=5, armor→0, class cleared
    assert_eq(player_armor, 0, "armor depletes to 0");
    assert_eq(player_armor_class, 0, "class cleared when armor hits 0");
    assert_eq(player_health, 65, "depleting armor still absorbs its remaining 5 (100-35)");

    # ============================================================
    test_group("collision: player vs solid things");
    # ============================================================
    # A solid thing (radius 10) 30u east; player radius 16 -> combined 26u.
    thing_count = 0;
    var so = things;
    store64(so, 30 << 16); store64(so + 8, 0);
    store64(so + 80, 10 << 16);                    # radius
    store64(so + 104, TF_ACTIVE | TF_SOLID);
    thing_count = 1;
    assert_eq(player_check_things(0, 0), 1, "30u away (>26) is clear of the solid thing");
    assert_eq(player_check_things(20 << 16, 0), 0, "10u away (<26) is blocked by the solid thing");
    # A corpse (TF_CORPSE, no SOLID) does not block.
    store64(so + 104, TF_ACTIVE | TF_CORPSE);
    assert_eq(player_check_things(20 << 16, 0), 1, "a corpse (non-solid) does not block");

    # ============================================================
    test_group("music: MUS synth voice (note-on -> tonal output)");
    # ============================================================
    # Exercise the synth directly (sequencer frozen via a large music_wait) so
    # it's WAD-free. A4 (MIDI 69, ~440 Hz) full volume on channel 0.
    music_init();
    music_playing = 1;
    music_wait = 1000000;              # freeze the sequencer (no score needed)
    music_note_on(0, 69, 127);
    var mactive = 0;
    for (var mv = 0; mv < MUSIC_VOICES; mv += 1) {
        if (load64(mv_state + mv * 8) != MV_FREE) { mactive += 1; }
    }
    assert_eq(mactive, 1, "note-on creates exactly one voice");
    var mpeak = 0; var mcross = 0; var mprev = 0;
    for (var mi = 0; mi < 2000; mi += 1) {
        var ms = music_render_sample();
        var ma = ms;
        if (ma < 0) { ma = 0 - ma; }
        if (ma > mpeak) { mpeak = ma; }
        if (mprev < 0) { if (ms >= 0) { mcross += 1; } }
        else { if (ms < 0) { mcross += 1; } }
        mprev = ms;
    }
    assert(mpeak > 0, "voice produces non-silent output");
    assert(mpeak < 32768, "output stays within S16 (no clip)");
    assert(mcross > 20, "output is tonal (A4 -> many zero-crossings)");
    # note-off releases the voice; env ramps to free.
    music_note_off(0, 69);
    var mg = 0;
    while (load64(mv_state) != MV_FREE && mg < 4000) { music_render_sample(); mg += 1; }
    assert_eq(load64(mv_state), MV_FREE, "note-off releases the voice");
    # Percussion (channel 15) is skipped in v1 — no voice.
    music_silence();
    music_note_on(15, 40, 127);
    var mperc = 0;
    for (var mp = 0; mp < MUSIC_VOICES; mp += 1) {
        if (load64(mv_state + mp * 8) != MV_FREE) { mperc += 1; }
    }
    assert_eq(mperc, 0, "percussion channel 15 takes no voice (v1)");

    # ============================================================
    test_group("music: stop silences the mix (--audio-test isolation, 0.32.1)");
    # ============================================================
    # --audio-test used to also play music: load_map() calls music_start()
    # (music_volume defaults to 8), and audio_tick()'s mixer adds
    # music_render_sample() into every source sample. --audio-test now calls
    # music_stop() first. Prove the mechanism: a playing voice renders sound
    # (it WOULD mix in), and after music_stop() every sample is pure silence,
    # so the SFX test is isolated.
    music_init();
    music_playing = 1;
    music_wait = 1000000;              # freeze the sequencer (WAD-free)
    music_note_on(0, 69, 127);
    var iso_pk = 0;
    for (var ii = 0; ii < 200; ii += 1) {
        var isv = music_render_sample();
        if (isv < 0) { isv = 0 - isv; }
        if (isv > iso_pk) { iso_pk = isv; }
    }
    assert(iso_pk > 0, "playing music renders sound (would mix into audio_tick)");
    music_stop();
    assert_eq(music_playing, 0, "music_stop clears music_playing");
    var iso_post = 0;
    for (var ij = 0; ij < 200; ij += 1) {
        if (music_render_sample() != 0) { iso_post += 1; }
    }
    assert_eq(iso_post, 0, "stopped music renders pure silence (audio-test SFX-only)");

    # ============================================================
    test_group("wayland: wire codec byte layout (v0.33.0, headless)");
    # ============================================================
    # The pure wire.cyr codec is the one Wayland piece CI can exercise without a
    # compositor. Assert the wire-format math the whole client depends on.
    var wbuf = alloc(64);
    # header: word0 = object id; word1 = (size<<16)|(opcode&0xFFFF)
    wire_hdr_put(wbuf, 5, 3, 12);
    assert_eq(wire_msg_id(wbuf), 5, "wire header object id");
    assert_eq(wire_msg_op(wbuf), 3, "wire header opcode");
    assert_eq(wire_msg_size(wbuf), 12, "wire header size");
    assert_eq(load32(wbuf + 4), (12 << 16) | 3, "wire word1 = (size<<16)|opcode");
    # string arg: u32 len(=strlen+1 incl NUL), bytes+NUL, padded to 4.
    var woff = wire_put_str(wbuf, 8, "wl_shm", 6);   # "wl_shm" = 6 chars -> L=7 -> pad to 8
    assert_eq(load32(wbuf + 8), 7, "wire string length = strlen+1 (incl NUL)");
    assert_eq(load8(wbuf + 12 + 6), 0, "wire string NUL-terminated");
    assert_eq(woff, 8 + 4 + 8, "wire string advances 4 + pad4(L)");
    assert_eq(wire_str_next(8, 7), 8 + 4 + 8, "wire_str_next matches (pad 7->8)");
    # exact-multiple-of-4 string: "wxyz" -> L=5 -> pad to 8
    wire_put_str(wbuf, 8, "wxyz", 4);
    assert_eq(wire_str_next(8, wire_str_len(wbuf, 8)), 8 + 4 + 8, "wire_str_next pad (L=5 -> 8)");
    # u32 writer advances 4.
    assert_eq(wire_put_u32(wbuf, 8, 0xABCD), 12, "wire_put_u32 advances 4");
    assert_eq(load32(wbuf + 8), 0xABCD, "wire_put_u32 stores value");

    # ============================================================
    test_group("wayland: wl__parse bounds untrusted registry (v0.33.0, headless)");
    # ============================================================
    # The wire parser is an untrusted-input boundary. A malformed wl_registry.global
    # claiming a huge string length must be rejected without reading past wl_rbuf
    # (the P(-1) hardening). Drive wl__parse against crafted bytes — no compositor.
    wl_rbuf = alloc(8192 + 64);
    wl_reg_id = 2;
    # Well-formed wl_registry.global for "wl_shm": id=2, op=0, name=5, len=7,
    # "wl_shm\0" (pad 8), version=1; total size = 28.
    store32(wl_rbuf, 2);
    store32(wl_rbuf + 4, (28 << 16) | 0);
    store32(wl_rbuf + 8, 5);          # name
    store32(wl_rbuf + 12, 7);         # strlen (incl NUL)
    memcpy(wl_rbuf + 16, "wl_shm", 6);
    store8(wl_rbuf + 22, 0);
    store32(wl_rbuf + 24, 1);         # version
    wl_gn_shm = 0;
    wl_rlen = 28;
    wl__parse();
    assert_eq(wl_gn_shm, 5, "well-formed registry global binds wl_shm name");
    # Malformed: same header but a huge string length. Must be rejected, no bind,
    # no OOB read/crash.
    store32(wl_rbuf, 2);
    store32(wl_rbuf + 4, (28 << 16) | 0);
    store32(wl_rbuf + 8, 9);
    store32(wl_rbuf + 12, 0xFFFF);    # hostile length >> message size
    store32(wl_rbuf + 24, 1);
    wl_gn_shm = 0; wl_gn_comp = 0; wl_gn_xdg = 0; wl_gn_seat = 0;
    wl_rlen = 28;
    wl__parse();
    assert_eq(wl_gn_shm, 0, "malformed registry global rejected (no bind, no OOB)");
    assert_eq(wl_gn_comp, 0, "malformed global sets no compositor");
    # A message claiming size < 8 aborts the parse safely.
    store32(wl_rbuf, 2);
    store32(wl_rbuf + 4, (4 << 16) | 0);   # size = 4 (< 8)
    wl_rlen = 8;
    assert_eq(wl__parse(), 0 - 1, "size<8 message aborts parse (returns -1)");

    # ============================================================
    # window: compositor-size clamp (v0.33.4, M-1/P-6, headless)
    # framebuf_present_wayland blits a fixed 320x200 frame, so the shm buffer must
    # never be smaller (M-1 crash) nor overflow-huge (P-6). win__clamp_size floors
    # to 320x200 and caps to WIN_MAX on both axes.
    # ============================================================
    test_group("window: compositor size clamp (M-1/P-6)");
    var c1w, c1h = win__clamp_size(300, 150);
    assert_eq(c1w, 320, "sub-min width floored to 320 (M-1)");
    assert_eq(c1h, 200, "sub-min height floored to 200 (M-1)");
    var c2w, c2h = win__clamp_size(640, 400);
    assert_eq(c2w, 640, "in-range width kept");
    assert_eq(c2h, 400, "in-range height kept");
    var c3w, c3h = win__clamp_size(2000000000, 2000000000);
    assert_eq(c3w, 16384, "overflow-huge width capped to WIN_MAX (P-6)");
    assert_eq(c3h, 16384, "overflow-huge height capped to WIN_MAX (P-6)");

    # ============================================================
    test_group("BSP: node cycle rejection (0.33.8 HIGH, pre-PWAD)");
    # ============================================================
    # A hostile WAD whose BSP nodes form a cycle would loop every BSP walk forever.
    # map_validate_bsp_acyclic must reject cycles/shared subtrees while accepting a
    # valid binary tree. Drive it against synthetic node arrays (children at +96/+104;
    # 0x8000 flag = subsector leaf). Save/restore the globals it reads.
    var bsp_save_nodes = map_nodes;
    var bsp_save_nn = map_num_nodes;
    var tn = alloc(4 * MAP_NODE_SIZE);
    map_nodes = tn;
    # Valid tree: root(1) -> right=node0, left=leaf; node0 -> two leaves.
    map_num_nodes = 2;
    store64(tn + 0 * MAP_NODE_SIZE + 96, 0x8000); store64(tn + 0 * MAP_NODE_SIZE + 104, 0x8001);
    store64(tn + 1 * MAP_NODE_SIZE + 96, 0);      store64(tn + 1 * MAP_NODE_SIZE + 104, 0x8000);
    assert_eq(map_validate_bsp_acyclic(), 0, "valid BSP tree accepted");
    # Cycle: node0 -> node1, root node1 -> node0.
    store64(tn + 0 * MAP_NODE_SIZE + 96, 1);
    store64(tn + 1 * MAP_NODE_SIZE + 96, 0);
    assert_eq(map_validate_bsp_acyclic(), 0 - 1, "cyclic BSP rejected (no infinite walk)");
    # Self-loop: single node referencing itself.
    map_num_nodes = 1;
    store64(tn + 0 * MAP_NODE_SIZE + 96, 0); store64(tn + 0 * MAP_NODE_SIZE + 104, 0x8000);
    assert_eq(map_validate_bsp_acyclic(), 0 - 1, "self-loop BSP rejected");
    # Out-of-range node child.
    store64(tn + 0 * MAP_NODE_SIZE + 96, 99);
    assert_eq(map_validate_bsp_acyclic(), 0 - 1, "out-of-range node child rejected");
    map_nodes = bsp_save_nodes;
    map_num_nodes = bsp_save_nn;

    # ============================================================
    # WAD tests require DOOM1.WAD — skip if not available
    # ============================================================

    var has_wad = 0;
    if (argc() > 1) {
        # v0.27.3 — wad_open now returns Result<i64, WadError>;
        # check the Ok tag instead of the legacy 0-on-success int.
        if (is_ok(wad_open(argv(1))) == 1) { has_wad = 1; }
    }

    if (has_wad == 1) {
        test_group("WAD parsing");

        assert_eq(wad_numlumps, 1264, "DOOM1.WAD has 1264 lumps");

        var pal = wad_find_lump("PLAYPAL");
        assert(pal >= 0, "PLAYPAL found");
        assert_eq(wad_lump_size(pal), 10752, "PLAYPAL size = 10752");

        var cmap = wad_find_lump("COLORMAP");
        assert(cmap >= 0, "COLORMAP found");
        assert_eq(wad_lump_size(cmap), 8704, "COLORMAP size = 8704");

        var tex1 = wad_find_lump("TEXTURE1");
        assert(tex1 >= 0, "TEXTURE1 found");

        var pnames = wad_find_lump("PNAMES");
        assert(pnames >= 0, "PNAMES found");

        var e1m1 = wad_find_lump("E1M1");
        assert(e1m1 >= 0, "E1M1 marker found");

        # ============================================================
        test_group("WAD lump read");
        # ============================================================

        var pd = wad_read_lump(pal);
        assert(pd != 0, "PLAYPAL data non-null");
        # Palette index 0 = black (0,0,0)
        assert_eq(load8(pd), 0, "pal[0].r = 0");
        assert_eq(load8(pd + 1), 0, "pal[0].g = 0");
        assert_eq(load8(pd + 2), 0, "pal[0].b = 0");
        # Palette index 4 = white (255,255,255)
        assert_eq(load8(pd + 12), 255, "pal[4].r = 255");

        # ============================================================
        test_group("map loading");
        # ============================================================

        framebuf_set_palette(pd);
        framebuf_init();

        assert_eq(map_load("E1M1"), 0, "E1M1 loads");
        assert_eq(map_num_vertexes, 467, "E1M1 vertexes = 467");
        assert_eq(map_num_linedefs, 475, "E1M1 linedefs = 475");
        assert_eq(map_num_sidedefs, 648, "E1M1 sidedefs = 648");
        assert_eq(map_num_sectors, 85, "E1M1 sectors = 85");
        assert_eq(map_num_segs, 732, "E1M1 segs = 732");
        assert_eq(map_num_ssectors, 237, "E1M1 subsectors = 237");
        assert_eq(map_num_nodes, 236, "E1M1 nodes = 236");
        assert_eq(map_num_things, 138, "E1M1 things = 138");

        # ============================================================
        test_group("player start");
        # ============================================================

        assert_eq(map_find_player_start(), 0, "player start found");
        assert_eq(fixed_to_int(player_start_x()), 1056, "start x = 1056");
        assert_eq(fixed_to_int(player_start_y()), 0 - 3616, "start y = -3616");

        # ============================================================
        test_group("sector data");
        # ============================================================

        # Sector 0 should have valid height data
        var fh = map_sector_floorh(0);
        var ch = map_sector_ceilh(0);
        assert(ch > fh, "ceil > floor for sector 0");

        var light = map_sector_light(0);
        assert(light >= 0, "light >= 0");
        assert(light <= 255, "light <= 255");

        # ============================================================
        test_group("texture loading");
        # ============================================================

        render_load_colormap();
        texture_init();

        var startan = texture_find("STARTAN3");
        assert(startan >= 0, "STARTAN3 found");
        assert_eq(texture_height(startan), 128, "STARTAN3 height = 128");

        var door3 = texture_find("DOOR3");
        assert(door3 >= 0, "DOOR3 found");

        # ============================================================
        test_group("status: name-scratch lump lookup (R-2)");
        # ============================================================
        # The death-face name "STFDEAD0" is EXACTLY 8 chars; st_name_buf must be 9
        # bytes so the NUL fits and wad_name_eq's strlen doesn't over-read the
        # adjacent face_patch_buf (which rejected every lump → blank death face).
        status_init_font();
        var fnb = st_name_buf();
        memcpy(fnb, "STFDEAD0", 8);
        store8(fnb + 8, 0);
        assert(wad_find_lump(fnb) >= 0, "STFDEAD0 death face resolves (R-2)");
        # STYSNUM digit names are also 8 chars ("STYSNUM"+digit) — the alloc(9)+NUL
        # fix in status_init_font; both endpoints must have resolved.
        assert(load64(st_ynums + 0) >= 0, "STYSNUM0 resolved (R-2 sibling)");
        assert(load64(st_ynums + 9 * 8) >= 0, "STYSNUM9 resolved (R-2 sibling)");

        # ============================================================
        test_group("COLORMAP");
        # ============================================================

        # Level 0 = full bright (identity map)
        assert_eq(render_shade(96, 0), 96, "shade(96, bright) = 96");
        # Level 31 = very dark
        var dark96 = render_shade(96, 31);
        assert(dark96 != 96, "shade(96, dark) != 96");
        # White stays white at full bright
        assert_eq(render_shade(4, 0), 4, "shade(white, bright) = white");

        # ============================================================
        test_group("collision (blockmap)");
        # ============================================================
        # Regression guard for the blockmap cell-index double-shift (latent
        # since 0.13.0, fixed 0.29.4): the buggy `fixed_to_int(asr(.,16))`
        # double-converted fixed->int (= asr 32), collapsing every query to
        # cell (0,0), so player_check_position returned 1 everywhere and the
        # player walked through all walls. A working system blocks SOMEWHERE on
        # a sweep through the spawn.
        player_init();
        assert_eq(player_check_position(player_x, player_y), 1, "spawn position is valid");
        var blk = 0;
        var sweep_d = 0 - (2048 << 16);
        while (sweep_d <= (2048 << 16)) {
            if (player_check_position(player_x + sweep_d, player_y) == 0) { blk = blk + 1; }
            if (player_check_position(player_x, player_y + sweep_d) == 0) { blk = blk + 1; }
            sweep_d = sweep_d + (64 << 16);
        }
        assert(blk > 0, "collision blocks on the spawn sweep (not walk-through-walls)");

        # ============================================================
        test_group("collision: drop-off wedge escape (0.33.1)");
        # ============================================================
        # Field repro: walking off the armor-walkway ledge (112-unit drop,
        # landing at (72,-3083) on the -8 nukage floor) left the player
        # inside the ledge line's radius; every move then re-failed the
        # step-up check — locked in place in all 8 directions. The escape
        # rule (move_check_linedef) allows same-side moves when the current
        # position already violates the line; only the crossing back into
        # the tall ledge stays vetoed.
        player_x = 72 << 16;
        player_y = 0 - (3083 << 16);
        player_z = 0 - (8 << 16);
        var free_dirs = 0;
        var wd = 0;
        while (wd < 8) {
            var wang = wd * 128;
            var wmx = fixed_mul(fixed_cos(wang), PLAYER_WALK_SPEED);
            var wmy = fixed_mul(fixed_sin(wang), PLAYER_WALK_SPEED);
            if (player_check_position(player_x + wmx, player_y + wmy) == 1) { free_dirs += 1; }
            wd += 1;
        }
        assert(free_dirs >= 6, "post-drop position escapable (was 0/8 directions free)");
        assert(free_dirs <= 7, "crossing back into the 112-unit ledge still vetoed");

        # ============================================================
        test_group("collision: monster moves use the MONSTER's floor (0.33.1)");
        # ============================================================
        # The wall pass step check used to read player_z for every mover:
        # monsters near ledges froze or un-froze depending on where the
        # PLAYER stood. An imp on the narrow zigzag pier at (3390,-3461)
        # (floor 96, inside the radius of edge line 201 over the -48 room
        # floor) is dropoff-pinned — vanilla MF_DROPOFF semantics — and the
        # verdict must NOT change when player_z does. Pre-fix, raising the
        # player to z=104 made the step check read 96-104 < 24 and the imp
        # could stroll off the 144-unit cliff.
        thing_count = 0;
        var tmv = things;
        store64(tmv, 3390 << 16); store64(tmv + 8, 0 - (3461 << 16));
        store64(tmv + 32, TTYPE_IMP); store64(tmv + 40, STATE_CHASE); store64(tmv + 48, 60);
        store64(tmv + 56, CAT_MONSTER); store64(tmv + 80, 20 << 16);
        store64(tmv + 104, TF_ACTIVE | TF_SOLID | TF_SHOOTABLE); store64(tmv + 112, 0);
        thing_count = 1;
        player_x = 3100 << 16; player_y = 0 - (3400 << 16);
        player_z = 0 - (24 << 16);
        assert_eq(thing_move_clear(0, thing_x(0) - 65536, thing_y(0)), 0,
            "pier imp refuses the west ledge (vanilla MF_DROPOFF)");
        player_z = 104 << 16;
        assert_eq(thing_move_clear(0, thing_x(0) - 65536, thing_y(0)), 0,
            "west verdict invariant under player_z (pre-fix: walked off the cliff)");
        # Open ground far from any ledge line: a chase step is legal and
        # equally player_z-invariant (pre-fix a LOW player froze HIGH-ground
        # monsters this way).
        store64(tmv, 2000 << 16); store64(tmv + 8, 0 - (3300 << 16));
        assert_eq(thing_move_clear(0, thing_x(0) + 65536, thing_y(0)), 1,
            "open-ground chase step legal");
        player_z = 0 - (300 << 16);
        assert_eq(thing_move_clear(0, thing_x(0) + 65536, thing_y(0)), 1,
            "open-ground verdict invariant under player_z");
        thing_count = 0;

        # ============================================================
        test_group("noise alert wakes sound-connected monsters (0.33.1)");
        # ============================================================
        # Vanilla P_NoiseAlert: gunfire floods sound through open portals and
        # stops at closed doors. E1M1's computer-room zombiemen are
        # 2D-sight-blocked behind the barred window, so before this they
        # ignored any amount of gunfire ("enemies not alive / shots don't
        # register" field report). 5 of the 6 HMP monsters are in door-free
        # sound range of the spawn; the southern-room imp (sector 74) is
        # behind the closed staircase door and correctly sleeps through it
        # (python BFS over the WAD's open portals confirms 74 unreachable).
        game_skill = 3;
        things_spawn_from_map();
        var idle0 = 0;
        for (var nm = 0; nm < thing_count; nm += 1) {
            if (thing_category(nm) == CAT_MONSTER && thing_state(nm) == STATE_SPAWN) { idle0 += 1; }
        }
        assert_eq(idle0, 6, "HMP E1M1 spawns 6 idle monsters");
        things_noise_alert(player_start_x(), player_start_y());
        var woke = 0;
        var asleep = 0;
        for (var nw = 0; nw < thing_count; nw += 1) {
            if (thing_category(nw) != CAT_MONSTER) { continue; }
            if (thing_state(nw) == STATE_SEE) { woke += 1; }
            if (thing_state(nw) == STATE_SPAWN) { asleep += 1; }
        }
        assert_eq(woke, 5, "one shot at spawn wakes the 5 door-free monsters");
        assert_eq(asleep, 1, "the closed south door keeps its imp asleep (vanilla)");
        things_spawn_from_map();

        # ============================================================
        test_group("rendering");
        # ============================================================

        render_load_sky();
        sprite_init();

        # ============================================================
        test_group("sprite: lookup coverage (RC-S3 regression)");
        # ============================================================
        # These 12 types spawned and functioned but had no lookup entry, so
        # they rendered INVISIBLE (63 attacking spectres across E1M3-M9,
        # every shell/rocket box, powerups, corpse decor).

        var sp_l, sp_f = sprite_find_frame(58, 1, 0);
        assert(sp_l >= 0, "spectre (58) resolves a SARG lump");
        assert(sprite_find_lump(2049) >= 0, "shell box (2049) resolves SBOXA0");
        assert(sprite_find_lump(2046) >= 0, "rocket box (2046) resolves BROKA0");
        assert(sprite_find_lump(2010) >= 0, "rocket ammo (2010) resolves ROCKA0");
        assert(sprite_find_lump(8) >= 0, "backpack (8) resolves BPAKA0");
        assert(sprite_find_lump(24) >= 0, "blood pool (24) resolves POL5A0");
        assert(sprite_find_lump(35) >= 0, "candelabra (35) resolves CBRAA0");
        assert(sprite_find_lump(2024) >= 0, "blur sphere (2024) resolves PINSA0");
        assert(sprite_find_lump(2025) >= 0, "radsuit (2025) resolves SUITA0");
        var dp_l, dp_f = sprite_find_frame(15, 0, 13);
        assert(dp_l >= 0, "dead marine (15) frame N resolves PLAYN0");
        var gb_l, gb_f = sprite_find_frame(10, 0, 22);
        assert(gb_l >= 0, "gibbed marine (10) frame W resolves PLAYW0");

        view_x = player_start_x();
        view_y = player_start_y();
        view_angle = player_start_angle();

        render_frame();
        sprite_render_all();

        # Should have drawn most of the screen
        var nonzero = 0;
        for (var i = 0; i < 64000; i = i + 1) {
            if (load8(screen_buf + i) != 0) { nonzero = nonzero + 1; }
        }
        assert(nonzero > 20000, "rendered > 20000 non-black pixels");
        assert_eq(clip_count, 320, "all 320 columns clipped");
        assert(ds_count > 0, "drawsegs recorded for the frame");
        assert(ds_count < DS_MAX, "drawseg count under DS_MAX cap");

        # ============================================================
        test_group("sprite: depth clipping (RC-S1 regression)");
        # ============================================================
        # A barrel 136 units dead ahead in provably-clear view (the sight
        # line crosses only a floor step). The old collapsed-clip sprite pass
        # deleted it entirely: window geometry far BEHIND it narrowed the
        # frame-final clip band above the barrel's rows. With per-drawseg
        # depth clipping the sprite pass must paint it.
        # (The combat groups above leave synthetic things behind — spawn the
        # real E1M1 set so the barrel exists.)
        things_spawn_from_map();
        view_x = 1312 << 16;
        view_y = (0 - 3400) << 16;
        view_angle = 256;
        render_frame();
        var spr_before = alloc(1104);
        var sbi = 0;
        for (var sy = 105; sy <= 150; sy += 1) {
            for (var sx = 149; sx <= 171; sx += 1) {
                store8(spr_before + sbi, framebuf_get_pixel(sx, sy));
                sbi += 1;
            }
        }
        sprite_render_all();
        var spr_changed = 0;
        sbi = 0;
        for (var sy = 105; sy <= 150; sy += 1) {
            for (var sx = 149; sx <= 171; sx += 1) {
                if (framebuf_get_pixel(sx, sy) != load8(spr_before + sbi)) { spr_changed += 1; }
                sbi += 1;
            }
        }
        assert(spr_changed > 50, "barrel dead ahead renders (was deleted by far-portal clip)");

        # ============================================================
        test_group("gameplay: closed doors block sight/use/missiles (RC-G3/G4/G5)");
        # ============================================================
        # E1M1's spawn-room door (lines 151/152, back sector 4) is CLOSED at
        # map load (ceil == floor == 0). Points straddle it at y = -2496.

        # RC-G4: sight through the closed door must be blocked (it used to
        # skip every two-sided line — bullets/wake straight through doors).
        assert_eq(thing_check_sight(1420 << 16, (0 - 2496) << 16, 1600 << 16, (0 - 2496) << 16), 0,
        "sight blocked through the closed door");
        assert_eq(thing_check_sight(1420 << 16, (0 - 2496) << 16, 1470 << 16, (0 - 2496) << 16), 1,
        "sight clear between two open points");

        # RC-G5: a rocket fired point-blank at the closed door must NOT
        # materialize on the far side (spawn offset is 32 units, the door
        # sector is 16 thick). The spawned missile must be in the shooter's
        # line of sight.
        player_x = 1520 << 16;
        player_y = (0 - 2496) << 16;
        var mi_idx = thing_spawn_missile(player_x, player_y, 0);
        assert(mi_idx >= 0, "missile spawned");
        assert_eq(thing_check_sight(player_x, player_y, thing_x(mi_idx), thing_y(mi_idx)), 1,
        "missile spawn point is on the shooter's side of the door");
        thing_set_flags(mi_idx, 0);

        # RC-G3: E only activates a special the use RAY crosses — facing away
        # from the door must not open it (the old midpoint heuristic opened
        # any special within 64 units in ANY direction).
        # (The game calls doors_init from load_map; the harness must too, or
        # door_start writes through a NULL thinker array.)
        doors_init();
        player_x = 1490 << 16;
        player_y = (0 - 2496) << 16;
        player_angle = 512;
        doors_use();
        assert_eq(door_count, 0, "facing AWAY from the door: E does nothing");
        player_angle = 0;
        doors_use();
        assert_eq(door_count, 1, "facing the door: E opens it");

        # ============================================================
        test_group("gameplay: closing door reverses on the player (RC-G1)");
        # ============================================================
        # Stand IN the doorway (sector 4) while it runs its open-wait-close
        # cycle: the ceiling must never squeeze below player height (it used
        # to close to 0 and entomb — a quit-only softlock on tag doors).
        player_x = 1544 << 16;
        player_y = (0 - 2496) << 16;
        # Track clearance only while the door is CLOSING — the door starts
        # shut, so its initial opening sweep passes through small clearances
        # by design.
        var min_clear = 100000;
        for (var dt = 0; dt < 500; dt += 1) {
            doors_tick();
            if (door_state(0) == DS_CLOSING) {
                var dc = load64(map_sectors + 4 * MAP_SECTOR_SIZE + 8) - load64(map_sectors + 4 * MAP_SECTOR_SIZE);
                if (dc < min_clear) { min_clear = dc; }
            }
        }
        assert(min_clear >= PLAYER_HEIGHT, "door never squeezes below player height while occupied");
        # Step out: the door must now complete its close.
        player_x = 1420 << 16;
        for (var dt = 0; dt < 600; dt += 1) { doors_tick(); }
        assert_eq(load64(map_sectors + 4 * MAP_SECTOR_SIZE + 8), 0, "door fully closes once the doorway is clear");

        # ============================================================
        test_group("floor: one-way lower latches, never raises (G-2)");
        # ============================================================
        # The floor-mover specials (23/38/70/71/102) used to route to lift_activate
        # (lower-wait-RAISE), re-sealing the path. DS_FLOOR_LOWER lowers and latches.
        doors_init();
        var f0 = load64(map_sectors + 4 * MAP_SECTOR_SIZE);          # sector 4 floor (offset 0)
        floor_lower_start(4, f0 - 64);
        assert_eq(door_count, 1, "floor-lower spawns a thinker");
        for (var dt = 0; dt < 200; dt += 1) { doors_tick(); }
        assert_eq(load64(map_sectors + 4 * MAP_SECTOR_SIZE), f0 - 64, "floor lowered to target");
        assert_eq(door_find_sector(4), 0 - 1, "one-way lower FREED its thinker (no wait/raise)");
        for (var dt = 0; dt < 300; dt += 1) { doors_tick(); }
        assert_eq(load64(map_sectors + 4 * MAP_SECTOR_SIZE), f0 - 64, "floor STAYS down (a lift would have raised)");
        # Lower-only: target at/above the current floor does nothing (no slot).
        doors_init();
        floor_lower_start(4, load64(map_sectors + 4 * MAP_SECTOR_SIZE) + 32);
        assert_eq(door_count, 0, "floor-lower with target above floor is a no-op");
        # Neighbor-floor helpers: highest-neighbor >= lowest (which includes self).
        assert(find_highest_neighbor_floor(4) >= find_lowest_neighbor_floor(4), "highest neighbor floor >= lowest");

        # ============================================================
        test_group("door: already-open stay door does not re-spawn/re-sound (G-8)");
        # ============================================================
        doors_init();
        # Ceiling raised above every neighbor → target (highest_neighbor-4) <= ceiling
        # → the already-open guard fires, no thinker, no DSDOROPN replay on held use.
        store64(map_sectors + 4 * MAP_SECTOR_SIZE + 8, 30000);
        door_open_stay(4);
        assert_eq(door_count, 0, "already-open door spawns no thinker (G-8)");
        # A genuinely closed door still opens.
        store64(map_sectors + 4 * MAP_SECTOR_SIZE + 8, 0);
        door_open_stay(4);
        assert_eq(door_count, 1, "closed door still spawns a thinker");

        # ============================================================
        test_group("door: opens to LOWEST neighbor ceiling (0.33.7 item 1)");
        # ============================================================
        # Vanilla P_FindLowestCeilingSurrounding: a door rises to the lowest
        # neighbor ceiling − 4, not the highest (find_highest overshot).
        doors_init();
        store64(map_sectors + 4 * MAP_SECTOR_SIZE + 8, 0);   # close it
        door_open(4);
        assert_eq(door_count, 1, "door opens");
        assert_eq(door_target(0), find_lowest_neighbor_ceil(4) - 4, "door target = lowest neighbor ceil − 4");

        # ============================================================
        test_group("linedef one-shot latch (0.33.7 item 3)");
        # ============================================================
        # special_is_once classifies W1/S1/D1 as once, DR/SR/WR as repeatable.
        assert_eq(special_is_once(31), 1, "31 D1 door = once");
        assert_eq(special_is_once(1), 0, "1 DR door = repeatable");
        assert_eq(special_is_once(29), 1, "29 S1 switch = once");
        assert_eq(special_is_once(63), 0, "63 SR switch = repeatable");
        assert_eq(special_is_once(10), 1, "10 W1 lift = once");
        assert_eq(special_is_once(88), 0, "88 WR lift = repeatable");
        assert_eq(special_is_once(32), 1, "32 D1 keyed = once");
        assert_eq(special_is_once(90), 0, "90 WR door = repeatable");
        # The tag-loop latch is restricted to the switch subset so a malformed WAD
        # that tags a keyed D1 door can't latch it keyless → unopenable.
        assert_eq(special_is_switch_once(29), 1, "29 S1 switch is a switch-once");
        assert_eq(special_is_switch_once(32), 0, "32 D1 keyed NOT a switch-once (stays key-retriable)");
        assert_eq(special_is_switch_once(63), 0, "63 SR switch is repeatable, not once");
        # The used-flag array marks/checks per linedef and clears on doors_init.
        doors_init();
        assert_eq(door_line_used(7), 0, "line 7 unused after doors_init");
        door_mark_used(7);
        assert_eq(door_line_used(7), 1, "line 7 latches used");
        doors_init();
        assert_eq(door_line_used(7), 0, "doors_init clears the latch (per-level)");

        wad_close();
    } else {
        syscall(1, 1, "(WAD tests skipped — pass WAD path as arg)\n", 44);
    }

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
