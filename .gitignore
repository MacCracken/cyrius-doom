# Build
/build/
/target/

# `lib/` is populated by `cyrius deps` from cyrius.cyml [deps] — a
# build artifact, not source. Stdlib modules are copied from
# $CYRIUS_HOME/lib/; [deps.X] git overrides are symlinked into
# $CYRIUS_HOME/deps/<name>/<tag>/. Never commit. Same shape as
# vani / yukti.
/lib/

# WAD files (user provides their own)
*.wad
*.WAD

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/

# Core dumps
*.core
